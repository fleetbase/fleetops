<Layout::Resource::Tabular
    @resource="fleet"
    @title={{t "resource.fleets"}}
    @searchQuery={{this.query}}
    @onSearch={{perform this.fleetActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @setupTable={{fn (mut this.table)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="layer-group"
        title="Create your first fleet"
        description="Fleets help group vehicles and drivers for dispatching, reporting, and operational coverage."
        filteredTitle="No fleets match your filters"
        filteredDescription="Adjust the search or filters to find another fleet."
        primaryText="New fleet"
        primaryIcon="plus"
        primaryAction=this.fleetActions.transition.create
        secondaryText="Import"
        secondaryIcon="upload"
        secondaryAction=this.fleetActions.import
        docsSlug="fleet-ops/resources/fleets/overview"
        docsTitle="Fleets guide"
        docsText="Fleet guide"
        docsSource="fleet-ops-empty-fleets"
    }}
/>
{{outlet}}
