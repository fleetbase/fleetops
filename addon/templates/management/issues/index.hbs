<Layout::Resource::Tabular
    @resource="issue"
    @title={{t "resource.issues"}}
    @searchQuery={{this.query}}
    @onSearch={{perform this.issueActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @setupTable={{fn (mut this.table)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="triangle-exclamation"
        title="No issues reported"
        description="Track vehicle, driver, facility, and service issues here so follow-up work stays visible."
        filteredTitle="No issues match your filters"
        filteredDescription="Clear the search or filters to review other reported issues."
        primaryText="New issue"
        primaryIcon="plus"
        primaryAction=this.issueActions.transition.create
        secondaryText="Import"
        secondaryIcon="upload"
        secondaryAction=this.issueActions.import
        docsSlug="fleet-ops/resources/issues/overview"
        docsTitle="Issues guide"
        docsText="Issues guide"
        docsSource="fleet-ops-empty-issues"
    }}
/>
{{outlet}}
