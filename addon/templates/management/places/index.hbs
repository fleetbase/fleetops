<Layout::Resource::Tabular
    @resource="place"
    @title={{t "resource.places"}}
    @searchQuery={{this.query}}
    @onSearch={{perform this.placeActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="location-dot"
        title="Add your first place"
        description="Places keep frequent pickup, dropoff, facility, and service locations ready for orders and routing."
        filteredTitle="No places match your filters"
        filteredDescription="Adjust the search or filters to find another saved location."
        primaryText="New place"
        primaryIcon="plus"
        primaryAction=this.placeActions.transition.create
        secondaryText="Import"
        secondaryIcon="upload"
        secondaryAction=this.placeActions.import
        docsSlug="fleet-ops/resources/places/overview"
        docsTitle="Places guide"
        docsText="Places guide"
        docsSource="fleet-ops-empty-places"
    }}
/>
{{outlet}}
