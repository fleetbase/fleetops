<Layout::Resource::Tabular
    @resource="maintenance"
    @title={{t "resource.maintenances"}}
    @searchQuery={{this.query}}
    @onSearch={{perform this.maintenanceActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="screwdriver-wrench"
        title="No maintenance records yet"
        description="Log maintenance events to keep service history, costs, and asset readiness visible."
        filteredTitle="No maintenance records match your filters"
        filteredDescription="Adjust the search or filters to find another maintenance record."
        primaryText="New maintenance"
        primaryIcon="plus"
        primaryAction=this.maintenanceActions.transition.create
        secondaryText="Import"
        secondaryIcon="upload"
        secondaryAction=this.maintenanceActions.import
    }}
/>
{{outlet}}
