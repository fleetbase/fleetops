<Layout::Resource::Panel
    @resource={{this.maintenance}}
    @controller={{this}}
    @headerTitle={{t "common.create-new-resource" resource=(lowercase (t "resource.maintenance"))}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "maintenance.maintenances.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <Maintenance::Form @resource={{this.maintenance}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>