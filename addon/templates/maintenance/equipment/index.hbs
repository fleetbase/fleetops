{{#if (eq this.layout "table")}}
    <Layout::Resource::Tabular
        @resource="equipment"
        @title={{t "resource.equipment"}}
        @searchQuery={{this.query}}
        @onSearch={{perform this.equipmentActions.controllerSearchTask this}}
        @data={{@model}}
        @columns={{this.columns}}
        @page={{this.page}}
        @onPageChange={{fn (mut this.page)}}
        @setupTable={{fn (mut this.table)}}
        @actionButtons={{this.actionButtons}}
        @bulkActions={{this.bulkActions}}
        @controller={{this}}
        @emptyStateComponent={{component
            "table/empty-state"
            icon="toolbox"
            title="Add your first equipment item"
            description="Equipment records help track assigned assets, condition, service history, and operational readiness."
            filteredTitle="No equipment matches your filters"
            filteredDescription="Adjust the search or filters to find another equipment item."
            primaryText="New equipment"
            primaryIcon="plus"
            primaryAction=this.equipmentActions.transition.create
            secondaryText="Import"
            secondaryIcon="upload"
            secondaryAction=this.equipmentActions.import
            docsSlug="fleet-ops/maintenance/equipment/overview"
            docsTitle="Equipment guide"
            docsText="Equipment guide"
            docsSource="fleet-ops-empty-equipment"
        }}
    />
{{else}}
    <Layout::Section::Header @title={{t "resource.equipment"}} @actionsWrapperClass="space-x-1">
        <Layout::Resource::TabularActions
            @searchQuery={{this.query}}
            @onSearch={{perform this.equipmentActions.controllerSearchTask this}}
            @columns={{this.columns}}
            @page={{this.page}}
            @onPageChange={{fn (mut this.page)}}
            @setupTable={{fn (mut this.table)}}
            @actionButtons={{this.actionButtons}}
            @bulkActions={{this.bulkActions}}
            @controller={{this}}
            @hideColumnsPicker={{true}}
        />
    </Layout::Section::Header>
    <Layout::Section::Body class="overflow-y-scroll-i h-full">
        <Layout::Resource::CardsGrid
            @resource="equipment"
            @data={{@model}}
            @gap="sm"
            @columns="4"
            @showPagination={{true}}
            @page={{this.page}}
            @onPageChange={{fn (mut this.page)}}
            @paginationMeta={{@model.meta}}
            @containerClass="p-4"
            class="h-full"
            as |Item|
        >
            <Equipment::Card @resource={{Item.model}} />
        </Layout::Resource::CardsGrid>
    </Layout::Section::Body>
{{/if}}
{{outlet}}
