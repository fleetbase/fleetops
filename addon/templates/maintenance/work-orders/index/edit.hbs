<Layout::Resource::Panel
    @resource={{@model}}
    @controller={{this}}
    @headerTitle={{t "common.edit-resource-name" resourceName=(or @model.code @model.subject)}}
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{this.cancel}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <WorkOrder::Form @resource={{@model}} @controller={{this}} @onCompletionChange={{this.onCompletionChange}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>