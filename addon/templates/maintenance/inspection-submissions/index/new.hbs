<Layout::Resource::Panel
    @resource={{this.inspectionSubmission}}
    @controller={{this}}
    @headerTitle="Create inspection"
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "maintenance.inspection-submissions.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <InspectionSubmission::Form @resource={{this.inspectionSubmission}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>
