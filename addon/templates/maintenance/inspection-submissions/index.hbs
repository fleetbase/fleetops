<Layout::Resource::Tabular
    @resource="inspection-submission"
    @title="Inspection Results"
    @searchQuery={{this.query}}
    @onSearch={{perform this.inspectionSubmissionActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="list-check"
        title="No inspections submitted yet"
        description="Capture DVIR submissions and turn failed items into issues or work orders."
        filteredTitle="No inspections match your filters"
        filteredDescription="Adjust search or filters to find another inspection."
        primaryText="New inspection"
        primaryIcon="plus"
        primaryAction=this.inspectionSubmissionActions.transition.create
        docsSlug="fleet-ops/maintenance/inspections/overview"
        docsTitle="Inspections guide"
        docsText="Inspections guide"
    }}
/>
{{outlet}}
