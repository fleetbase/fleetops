<Overlay
    @title={{t "common.edit-resource-name" resourceName=@model.name}}
    @onClose={{transition-to "maintenance.schedules.index"}}
    @width="500px"
>
    <Overlay::Body>
        <Schedule::Form @resource={{@model}} />
    </Overlay::Body>
    <Overlay::Footer>
        <Button @type="primary" @text={{t "common.save-changes"}} @onClick={{perform this.scheduleActions.saveTask @model}} />
        <Button @text={{t "common.cancel"}} @onClick={{transition-to "maintenance.schedules.index"}} />
    </Overlay::Footer>
</Overlay>
