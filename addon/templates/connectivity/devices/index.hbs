<Layout::Resource::Tabular
    @resource="device"
    @title={{t "resource.devices"}}
    @searchQuery={{this.query}}
    @onSearch={{perform this.deviceActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="tablet-screen-button"
        title="Add your first device"
        description="Devices connect vehicles and assets to telemetry, events, tracking, and provider syncs."
        filteredTitle="No devices match your filters"
        filteredDescription="Adjust the search or filters to find another device."
        primaryText="New device"
        primaryIcon="plus"
        primaryAction=this.deviceActions.transition.create
        secondaryText="Import"
        secondaryIcon="upload"
        secondaryAction=this.deviceActions.import
        docsSlug="fleet-ops/connectivity/devices/overview"
        docsTitle="Devices guide"
        docsText="Device guide"
        docsSource="fleet-ops-empty-devices"
    }}
/>
{{outlet}}
