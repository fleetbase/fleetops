<div class="flex flex-col gap-4 p-4 md:p-6">
    <div class="flex flex-col gap-1">
        <h2 class="text-base font-bold text-gray-900 dark:text-gray-100">Vehicle Attachment Mapping</h2>
        <p class="text-sm text-gray-500 dark:text-gray-300">Map synced provider devices to vehicles so telemetry can power vehicle state, maintenance, and operations workflows.</p>
    </div>

    <section class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-5">
        {{#each this.metrics as |metric|}}
            <div class="fleet-ops-widget fleet-ops-kpi-tile fleetops-connectivity-kpi-tile {{metric.accentClass}} relative min-h-[102px] overflow-hidden rounded-md border bg-white shadow-sm dark:bg-gray-800">
                <div class="flex h-full items-start justify-between gap-3 p-3">
                    <div class="min-w-0">
                        <div class="truncate text-[10px] font-bold uppercase text-gray-500 dark:text-gray-400">{{metric.label}}</div>
                        <div class="mt-2 text-2xl font-extrabold leading-none text-gray-900 dark:text-gray-50">{{metric.value}}</div>
                    </div>
                    <div class="fleetops-connectivity-kpi-icon flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-md text-[13px]">
                        <FaIcon @icon={{metric.icon}} />
                    </div>
                </div>
            </div>
        {{/each}}
    </section>

    <section class="overflow-hidden rounded-md border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="grid grid-cols-1 gap-3 border-b border-gray-200 px-4 py-3 dark:border-gray-700 xl:grid-cols-[minmax(18rem,28rem)_minmax(0,1fr)] xl:items-start">
            <div class="max-w-xl">
                <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100">Attachment Workspace</h3>
                <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-300">
                    Loaded
                    {{this.syncedDevices.length}}
                    of
                    {{this.totalSyncedDevices}}
                    synced devices. Search and filter locally without hiding the real totals.
                </p>
            </div>
            <div class="grid w-full min-w-0 grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-[minmax(18rem,1fr)_10rem_12rem_14rem_auto] xl:justify-end">
                <Input
                    @value={{this.query}}
                    @type="text"
                    class="form-input form-input-sm w-full"
                    placeholder="Search vehicles or devices"
                    {{on "input" this.updateQuery}}
                />
                <select class="form-select form-select-sm w-full" {{on "change" this.updateAttachmentState}}>
                    <option value="" selected={{not this.attachment_state}}>All mappings</option>
                    <option value="unattached" selected={{eq this.attachment_state "unattached"}}>Unattached</option>
                    <option value="attached" selected={{eq this.attachment_state "attached"}}>Attached</option>
                </select>
                <select class="form-select form-select-sm w-full" {{on "change" this.updateStatus}}>
                    <option value="" selected={{not this.status}}>Any status</option>
                    <option value="active" selected={{eq this.status "active"}}>Active</option>
                    <option value="online" selected={{eq this.status "online"}}>Online</option>
                    <option value="recently_offline" selected={{eq this.status "recently_offline"}}>Recently offline</option>
                    <option value="offline" selected={{eq this.status "offline"}}>Offline</option>
                    <option value="long_offline" selected={{eq this.status "long_offline"}}>Long offline</option>
                    <option value="never_connected" selected={{eq this.status "never_connected"}}>Never connected</option>
                    <option value="inactive" selected={{eq this.status "inactive"}}>Inactive</option>
                </select>
                <div class="min-w-0">
                    <ModelSelect
                        @modelName="vehicle"
                        @query={{hash telematic_uuid=this.telematic.id}}
                        @selectedModel={{this.vehicle}}
                        @placeholder="Any vehicle"
                        @triggerClass="fleetops-attachments-vehicle-filter-trigger form-select form-select-sm w-full"
                        @infiniteScroll={{false}}
                        @renderInPlace={{false}}
                        @allowClear={{true}}
                        @onChangeId={{this.updateVehicle}}
                        as |vehicle|
                    >
                        {{vehicle.displayName}}
                    </ModelSelect>
                </div>
                <Button @icon="refresh" @size="sm" @onClick={{this.refresh}} />
            </div>
        </div>

        {{#if (or (eq this.emptyStateVariant "error") (eq this.emptyStateVariant "not_synced") (eq this.emptyStateVariant "filtered_empty"))}}
            <div class="p-4">
                <Telematic::TabEmptyState
                    @tone={{this.emptyStateContent.tone}}
                    @icon={{this.emptyStateContent.icon}}
                    @title={{this.emptyStateContent.title}}
                    @message={{this.emptyStateContent.message}}
                    @note={{this.emptyStateContent.note}}
                    @primaryText={{this.emptyStateContent.primaryText}}
                    @primaryIcon={{this.emptyStateContent.primaryIcon}}
                    @primaryAction={{this.emptyStateContent.primaryAction}}
                    @secondaryText={{this.emptyStateContent.secondaryText}}
                    @secondaryIcon={{this.emptyStateContent.secondaryIcon}}
                    @secondaryAction={{this.emptyStateContent.secondaryAction}}
                />
            </div>
        {{else}}
            <div class="grid grid-cols-1 divide-y divide-gray-200 dark:divide-gray-700 md:grid-cols-[minmax(18rem,0.85fr)_minmax(0,1.15fr)] md:divide-x md:divide-y-0">
                <div class="min-w-0 bg-yellow-50/60 dark:bg-yellow-900/10">
                    <div class="sticky top-0 z-10 border-b border-yellow-200 bg-yellow-50/95 px-4 py-3 backdrop-blur dark:border-yellow-800 dark:bg-gray-800/95">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <h4 class="text-sm font-bold text-gray-900 dark:text-gray-100">Unattached Devices</h4>
                                <p class="mt-1 text-xs leading-5 text-yellow-800 dark:text-yellow-300">Synced devices that still need a vehicle mapping.</p>
                            </div>
                            <Badge @status={{if this.filteredUnattachedCount "warning" "success"}} @hideStatusDot={{true}}>
                                {{this.filteredUnattachedCount}}
                                shown
                            </Badge>
                        </div>
                    </div>

                    <div class="h-[calc(100vh-24rem)] min-h-[28rem] overflow-y-auto p-3">
                        {{#if this.unattachedDevices.length}}
                            <div class="grid grid-cols-1 gap-2">
                                {{#each this.unattachedDevices as |device|}}
                                    <div class="rounded-md border border-yellow-200 bg-white p-3 shadow-sm dark:border-yellow-700 dark:bg-gray-800">
                                        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                                            <div class="min-w-0">
                                                <Device::Pill @device={{device}} />
                                                <div class="mt-2 grid grid-cols-2 gap-2 text-xs">
                                                    <div class="min-w-0">
                                                        <div class="text-gray-400 dark:text-gray-500">Provider ID</div>
                                                        <div class="truncate font-semibold text-gray-900 dark:text-gray-100">{{n-a device.device_id}}</div>
                                                    </div>
                                                    <div class="min-w-0">
                                                        <div class="text-gray-400 dark:text-gray-500">Connection</div>
                                                        <div class="truncate font-semibold text-gray-900 dark:text-gray-100">{{n-a device.connection_status}}</div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="flex flex-shrink-0 items-center gap-2">
                                                <Button @icon="eye" @size="sm" @onClick={{fn this.deviceActions.transition.view device}} />
                                                <Button @icon="link" @text="Attach" @size="sm" @type="primary" @onClick={{fn this.openAttachDeviceModal device}} />
                                            </div>
                                        </div>
                                    </div>
                                {{/each}}
                            </div>
                        {{else}}
                            <div class="rounded-md border border-green-200 bg-green-50 p-4 text-sm text-green-800 dark:border-green-700 dark:bg-green-900/20 dark:text-green-300">
                                All visible synced devices are mapped to vehicles.
                            </div>
                        {{/if}}
                    </div>
                </div>

                <div class="min-w-0">
                    <div class="sticky top-0 z-10 border-b border-gray-200 bg-white/95 px-4 py-3 backdrop-blur dark:border-gray-700 dark:bg-gray-800/95">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <h4 class="text-sm font-bold text-gray-900 dark:text-gray-100">Attached Vehicles</h4>
                                <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-300">Vehicle groups built from provider devices already attached to vehicles.</p>
                            </div>
                            <Badge @status={{if this.filteredAttachedCount "info" "default"}} @hideStatusDot={{true}}>
                                {{this.filteredAttachedCount}}
                                shown
                            </Badge>
                        </div>
                    </div>

                    <div class="h-[calc(100vh-24rem)] min-h-[28rem] overflow-y-auto">
                        {{#if this.vehicleGroups.length}}
                            {{#each this.vehicleGroups as |group|}}
                                <div class="border-b border-gray-200 px-4 py-3 last:border-b-0 dark:border-gray-700">
                                    <div class="mb-3 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                                        <div class="min-w-0">
                                            <h5 class="truncate text-sm font-bold text-gray-900 dark:text-gray-100">{{group.name}}</h5>
                                            <p class="text-xs text-gray-500 dark:text-gray-300">{{group.devices.length}} attached provider devices</p>
                                        </div>
                                        <Badge @status="info" @hideStatusDot={{true}}>Vehicle mapped</Badge>
                                    </div>

                                    <div class="overflow-hidden rounded-md border border-gray-200 dark:border-gray-700">
                                        {{#each group.devices as |device|}}
                                            <div class="grid grid-cols-1 gap-3 border-b border-gray-200 p-3 last:border-b-0 dark:border-gray-700 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)_auto] lg:items-center">
                                                <Device::Pill @device={{device}} />
                                                <div class="grid grid-cols-2 gap-2 text-xs">
                                                    <div class="min-w-0">
                                                        <div class="text-gray-400 dark:text-gray-500">Provider ID</div>
                                                        <div class="truncate font-semibold text-gray-900 dark:text-gray-100">{{n-a device.device_id}}</div>
                                                    </div>
                                                    <div class="min-w-0">
                                                        <div class="text-gray-400 dark:text-gray-500">Last seen</div>
                                                        <div class="truncate font-semibold text-gray-900 dark:text-gray-100">{{n-a (format-date-fns device.last_online_at "dd MMM HH:mm")}}</div>
                                                    </div>
                                                </div>
                                                <div class="flex flex-wrap items-center gap-2 lg:justify-end">
                                                    <Button @icon="eye" @size="sm" @onClick={{fn this.deviceActions.transition.view device}} />
                                                    <Button @icon="shuffle" @text="Change" @size="sm" @onClick={{fn this.openAttachDeviceModal device}} />
                                                    <Button @icon="unlink" @text="Detach" @size="sm" @type="danger" @onClick={{fn this.detachDevice device}} />
                                                </div>
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/each}}
                        {{else}}
                            <div class="p-4">
                                <div class="rounded-md border border-gray-200 bg-gray-50 p-4 text-sm text-gray-600 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300">
                                    No visible vehicle groups. Attach a device from the unattached pane or adjust the filters.
                                </div>
                            </div>
                        {{/if}}
                    </div>
                </div>
            </div>
        {{/if}}
    </section>
</div>
