<div class="flex flex-col gap-4">
    <div class="flex flex-col gap-3 rounded-md border border-gray-200 bg-white p-3 dark:border-gray-700 dark:bg-gray-800 md:flex-row md:items-center md:justify-between">
        <div>
            <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100">Vehicle Attachments</h2>
            <p class="text-xs text-gray-500 dark:text-gray-300">Review synced devices and attach them to the vehicles they report from.</p>
        </div>
        <Badge @status={{if this.unattachedDevices.length "warning" "success"}} @hideStatusDot={{true}}>
            {{this.unattachedDevices.length}} unattached
        </Badge>
    </div>

    {{#if this.unattachedDevices.length}}
        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
            {{#each this.unattachedDevices as |device|}}
                <div class="rounded-md border border-yellow-200 bg-yellow-50 p-3 dark:border-yellow-700 dark:bg-gray-800">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <div class="truncate text-sm font-bold text-gray-900 dark:text-gray-100">{{or device.displayName device.name device.device_id}}</div>
                            <div class="truncate text-xs text-gray-500 dark:text-gray-300">{{n-a device.device_id}}</div>
                        </div>
                        <Badge @status="warning" @hideStatusDot={{true}}>Needs vehicle</Badge>
                    </div>
                    <div class="mt-3 flex items-center gap-2">
                        <Button @icon="eye" @text="Open Device" @size="xs" @onClick={{fn this.deviceActions.transition.view device}} />
                        <Button @icon="link" @text="Attach" @size="xs" @type="primary" @onClick={{fn this.deviceActions.transition.edit device}} />
                    </div>
                </div>
            {{/each}}
        </div>
    {{/if}}

    <Layout::Resource::Tabular
        @resource="device"
        @title="Synced Device Attachments"
        @data={{@model}}
        @columns={{this.columns}}
        @controller={{this}}
    />
</div>
