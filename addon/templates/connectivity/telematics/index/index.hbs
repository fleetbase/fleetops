<Telematic::Hub
    @integrations={{@model}}
    @providers={{this.index.providers}}
    @providersLoading={{this.index.loadProviders.isRunning}}
    @columns={{this.index.columns}}
    @page={{this.index.page}}
    @onPageChange={{fn (mut this.index.page)}}
    @bulkActions={{this.index.bulkActions}}
    @controller={{this.index}}
    @searchQuery={{this.index.query}}
    @onSearch={{perform this.index.telematicActions.controllerSearchTask this.index}}
/>
