<Layout::Resource::Panel
    @resource={{@model}}
    @controller={{this}}
    @headerTitle={{t "common.edit-resource-name" resourceName=@model.name}}
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{this.cancel}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <RecurringOrderSchedule::Form @resource={{@model}} />
</Layout::Resource::Panel>