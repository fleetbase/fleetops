<Layout::Resource::Panel
    @resource={{this.schedule}}
    @controller={{this}}
    @headerTitle={{t "common.create-new-resource" resource=(lowercase (t "resource.recurring-order-schedule"))}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "operations.recurring-orders.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <RecurringOrderSchedule::Form @resource={{this.schedule}} @sourceOrder={{this.sourceOrder}} />
</Layout::Resource::Panel>