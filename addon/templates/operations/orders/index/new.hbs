<Layout::Resource::Panel
    @resource={{this.order}}
    @controller={{this}}
    @actionButtons={{this.actionButtons}}
    @headerTitle={{this.headerTitle}}
    @saveTask={{this.save}}
    @saveDisabled={{this.saveDisabled}}
    @onPressCancel={{transition-to "operations.orders.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
    @width="530px"
    @onOpen={{this.setup}}
    class="new-order-panel"
>
    <Order::Form
        @resource={{this.order}}
        @controller={{this}}
        @repeatEnabled={{this.repeatEnabled}}
        @scheduleFirst={{this.scheduleFirst}}
        @seriesDraft={{this.seriesDraft}}
        @onRepeatChange={{this.onRepeatChange}}
    />
    <Spacer @height="300px" />
</Layout::Resource::Panel>
