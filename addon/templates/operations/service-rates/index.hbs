<Layout::Resource::Tabular
    @resource="service-rate"
    @title={{t "resource.service-rates"}}
    @searchQuery={{this.query}}
    @onSearch={{perform this.serviceRateActions.controllerSearchTask this}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @emptyStateComponent={{component
        "table/empty-state"
        icon="route"
        title="Set up your first service rate"
        description="Service rates define how FleetOps prices routes, zones, distance, and other service rules."
        filteredTitle="No service rates match your filters"
        filteredDescription="Adjust the search or filters to find another service rate."
        primaryText="New service rate"
        primaryIcon="plus"
        primaryAction=this.serviceRateActions.transition.create
        secondaryText="Refresh"
        secondaryIcon="refresh"
        secondaryAction=this.serviceRateActions.refresh
        docsSlug="fleet-ops/operations/service-rates/overview"
        docsTitle="Service rates guide"
        docsText="Service rates guide"
        docsSource="fleet-ops-empty-service-rates"
    }}
/>
{{outlet}}
