<Layout::Section::Header @title={{t "allocation.settings-title"}}>
    <Button
        @type="primary"
        @size="sm"
        @icon="save"
        @text={{t "common.save-changes"}}
        @onClick={{perform this.saveSettings}}
        @disabled={{this.saveSettings.isRunning}}
        @isLoading={{or this.saveSettings.isRunning this.loadSettings.isRunning}}
    />
</Layout::Section::Header>
<Layout::Section::Body class="overflow-y-scroll h-full">
    <div class="container mx-auto h-screen">
        <div class="max-w-3xl my-10 mx-auto space-y-6">
            {{#if this.loadSettings.isRunning}}
                <div class="flex items-center justify-center py-12">
                    <Spinner />
                </div>
            {{else}}
                {{! ── Allocation Engine ──────────────────────────────────────── }}
                <ContentPanel @title={{t "allocation.engine-settings"}} @open={{true}} @wrapperClass="bordered-classic">
                    <InputGroup @name={{t "allocation.active-engine"}} @helpText={{t "allocation.active-engine-help"}}>
                        <Select
                            @value={{this.allocationEngine}}
                            @options={{this.engineOptions}}
                            @optionLabel="name"
                            @optionValue="id"
                            @onSelect={{fn (mut this.allocationEngine)}}
                            @placeholder={{t "allocation.active-engine"}}
                            class="w-full"
                        />
                    </InputGroup>
                    <InputGroup @name={{t "allocation.auto-allocate-on-create"}}>
                        <Toggle
                            @isToggled={{this.autoAllocateOnCreate}}
                            @onToggle={{fn (mut this.autoAllocateOnCreate)}}
                            @label={{t "allocation.auto-allocate-on-create-label"}}
                        />
                    </InputGroup>
                    <InputGroup @name={{t "allocation.auto-reallocate-on-complete"}}>
                        <Toggle
                            @isToggled={{this.autoReallocateOnComplete}}
                            @onToggle={{fn (mut this.autoReallocateOnComplete)}}
                            @label={{t "allocation.auto-reallocate-on-complete-label"}}
                        />
                    </InputGroup>
                </ContentPanel>
                {{! ── Allocation Constraints ─────────────────────────────────── }}
                <ContentPanel @title={{t "allocation.constraint-settings"}} @open={{true}} @wrapperClass="bordered-classic">
                    <InputGroup @name={{t "allocation.max-travel-time"}} @helpText={{t "allocation.max-travel-time-help"}}>
                        <Input
                            @type="number"
                            @value={{this.maxTravelTimeSeconds}}
                            min="0"
                            step="300"
                            class="w-full form-input"
                        />
                    </InputGroup>
                    <InputGroup @name={{t "allocation.balance-workload"}}>
                        <Toggle
                            @isToggled={{this.balanceWorkload}}
                            @onToggle={{fn (mut this.balanceWorkload)}}
                            @label={{t "allocation.balance-workload-label"}}
                        />
                    </InputGroup>
                </ContentPanel>
                <RegistryYield @registry="fleet-ops:template:settings:order-allocation" as |RegistryComponent|>
                    <RegistryComponent @controller={{this}} />
                </RegistryYield>
            {{/if}}
        </div>
    </div>
    <Spacer @height="600px" />
</Layout::Section::Body>
