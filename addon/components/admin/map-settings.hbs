<ContentPanel @title="Configure Map" @open={{true}} @wrapperClass="bordered-classic">
    <InputGroup @name="Default Map Provider" @helpText="Sets the default map provider for all organizations unless they override it in their own FleetOps map settings.">
        <Select
            class="w-full flex-1"
            @value={{this.mapProvider}}
            @options={{this.mapProviderOptions}}
            @optionLabel="label"
            @optionValue="value"
            @placeholder="Select default map provider"
            @onSelect={{this.selectMapProvider}}
        />
    </InputGroup>
    <InputGroup @name="Google Map ID" @value={{this.googleMapsMapId}} @helpText="Required for Google Advanced Markers and cloud-based map styling." />
</ContentPanel>

<EmberWormhole @to="next-view-section-subheader-actions">
    <Button
        @type="primary"
        @size="sm"
        @icon="save"
        @text="Save Changes"
        @onClick={{perform this.saveSettings}}
        @isLoading={{or this.saveSettings.isRunning this.loadSettings.isRunning}}
        @disabled={{this.saveSettings.isRunning}}
    />
</EmberWormhole>