<div class="flex flex-col" ...attributes>
    <span class="text-sm text-gray-800 dark:text-gray-100">
        {{#if @value}}
            {{format-date-fns @value "d MMM yyyy HH:mm"}}
        {{else}}
            --
        {{/if}}
    </span>
    {{#if @row.timezone}}
        <span class="text-xs text-gray-500 dark:text-gray-400">{{@row.timezone}}</span>
    {{/if}}
</div>
