<ContentPanel @title={{t "map-settings.map-settings"}} @open={{true}} @wrapperClass="bordered-classic">
    {{#if this.mapSettingsLoaded}}

        {{!-- ─── Map Provider Selection ──────────────────────────────────────── --}}
        <InputGroup
            @name={{t "map-settings.map-provider"}}
            @helpText={{t "map-settings.map-provider-help-text"}}
        >
            <Select
                class="w-full flex-1"
                @value={{this.selectedMapProvider}}
                @options={{this.mapProviderOptions}}
                @optionLabel="label"
                @optionValue="value"
                @placeholder={{t "map-settings.select-map-provider"}}
                @onSelect={{this.selectMapProvider}}
            />
        </InputGroup>

        {{!-- ─── Google Maps Options (shown only when Google Maps is selected) ── --}}
        {{#if this.isGoogleMapsSelected}}

            <InputGroup
                @name={{t "map-settings.google-maps-api-key"}}
                @helpText={{t "map-settings.google-maps-api-key-help-text"}}
            >
                <Input
                    class="form-input w-full"
                    type="password"
                    value={{this.mapSettings.googleMapsApiKey}}
                    placeholder={{t "map-settings.google-maps-api-key-placeholder"}}
                    {{on "input" this.onApiKeyChange}}
                />
            </InputGroup>

            <InputGroup
                @name={{t "map-settings.google-maps-map-type"}}
                @helpText={{t "map-settings.google-maps-map-type-help-text"}}
            >
                <Select
                    class="w-full flex-1"
                    @value={{this.selectedGoogleMapType}}
                    @options={{this.googleMapTypeOptions}}
                    @optionLabel="label"
                    @optionValue="value"
                    @placeholder={{t "map-settings.select-map-type"}}
                    @onSelect={{this.selectGoogleMapType}}
                />
            </InputGroup>

            <InputGroup>
                <div class="flex items-center">
                    <Toggle
                        @isToggled={{this.mapSettings.googleMapsTrafficLayer}}
                        @onToggle={{this.toggleTrafficLayer}}
                        @label={{t "map-settings.show-traffic-layer"}}
                        @helpText={{t "map-settings.show-traffic-layer-help-text"}}
                    />
                </div>
            </InputGroup>

            <InputGroup>
                <div class="flex items-center">
                    <Toggle
                        @isToggled={{this.mapSettings.googleMapsTransitLayer}}
                        @onToggle={{this.toggleTransitLayer}}
                        @label={{t "map-settings.show-transit-layer"}}
                        @helpText={{t "map-settings.show-transit-layer-help-text"}}
                    />
                </div>
            </InputGroup>

            {{!-- API Key requirements info box --}}
            <div class="rounded-md bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 p-3 mb-4">
                <div class="flex items-start space-x-2">
                    <FaIcon @icon="circle-info" class="text-blue-500 mt-0.5 flex-shrink-0" />
                    <div class="text-xs text-blue-700 dark:text-blue-300">
                        <p class="font-semibold mb-1">{{t "map-settings.google-api-key-requirements-title"}}</p>
                        <ul class="list-disc list-inside space-y-0.5">
                            <li>{{t "map-settings.google-api-key-requirement-maps-js"}}</li>
                            <li>{{t "map-settings.google-api-key-requirement-drawing"}}</li>
                            <li>{{t "map-settings.google-api-key-requirement-geometry"}}</li>
                            <li>{{t "map-settings.google-api-key-requirement-geocoding"}}</li>
                        </ul>
                    </div>
                </div>
            </div>

        {{/if}}

        {{!-- ─── Save Button ──────────────────────────────────────────────────── --}}
        <div class="mt-3 flex items-center mb-4">
            <Button
                @type="primary"
                @size="sm"
                @icon="save"
                @text={{t "common.save-changes"}}
                @onClick={{perform this.saveMapSettings}}
                @isLoading={{not this.saveMapSettings.isIdle}}
                @permission="fleet-ops update map-settings"
            />
        </div>

    {{else}}
        <div class="flex items-center justify-center py-8">
            <Spinner />
        </div>
    {{/if}}
</ContentPanel>
