<div class="work-order-details">

    {{! ===== OVERVIEW ===== }}
    <ContentPanel @title="Overview" @open={{true}}>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
            <div class="field-info-container">
                <div class="field-name">Code</div>
                <div class="field-value">{{n-a @resource.code}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Public ID</div>
                <div class="field-value">{{n-a @resource.public_id}}</div>
            </div>
            <div class="field-info-container col-span-3">
                <div class="field-name">Subject</div>
                <div class="field-value">{{n-a @resource.subject}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Status</div>
                <div class="field-value">
                    <Badge @status={{@resource.status}}>{{smart-humanize @resource.status}}</Badge>
                </div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Priority</div>
                <div class="field-value">
                    {{#if (eq @resource.priority "critical")}}
                        <Badge @status="danger">Critical</Badge>
                    {{else if (eq @resource.priority "high")}}
                        <Badge @status="warning">High</Badge>
                    {{else if (eq @resource.priority "medium")}}
                        <Badge @status="info">Medium</Badge>
                    {{else}}
                        <Badge @status="default">Low</Badge>
                    {{/if}}
                </div>
            </div>
        </div>
    </ContentPanel>

    {{! ===== ASSIGNMENT ===== }}
    <ContentPanel @title="Assignment" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
            <div class="field-info-container">
                <div class="field-name">Target</div>
                <div class="field-value">{{n-a @resource.target.displayName}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Assignee</div>
                <div class="field-value">{{n-a @resource.assignee.displayName}}</div>
            </div>
        </div>
    </ContentPanel>

    {{! ===== SCHEDULING ===== }}
    <ContentPanel @title="Scheduling" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
            <div class="field-info-container">
                <div class="field-name">Opened At</div>
                <div class="field-value">{{format-date @resource.opened_at}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Due At</div>
                <div class="field-value">{{format-date @resource.due_at}}</div>
            </div>
            <div class="field-info-container">
                <div class="field-name">Closed At</div>
                <div class="field-value">{{format-date @resource.closed_at}}</div>
            </div>
            {{#if @resource.schedule}}
                <div class="field-info-container">
                    <div class="field-name">Schedule</div>
                    <div class="field-value">{{n-a @resource.schedule.name}}</div>
                </div>
            {{/if}}
        </div>
    </ContentPanel>

    {{! ===== INSTRUCTIONS ===== }}
    {{#if @resource.instructions}}
        <ContentPanel @title="Instructions" @open={{false}} @wrapperClass="bordered-top">
            <div class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap">
                {{@resource.instructions}}
            </div>
        </ContentPanel>
    {{/if}}

    {{! ===== COMPLETION / COST BREAKDOWN ===== }}
    {{#if (eq @resource.status "closed")}}
        <ContentPanel @title="Completion & Cost Breakdown" @open={{true}} @wrapperClass="bordered-top">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
                <div class="col-span-3 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mb-1">
                    Asset Readings at Completion
                </div>
                <div class="field-info-container">
                    <div class="field-name">Odometer</div>
                    <div class="field-value">
                        {{#if @resource.meta.completion_data.odometer}}
                            {{@resource.meta.completion_data.odometer}} km
                        {{else}}
                            —
                        {{/if}}
                    </div>
                </div>
                <div class="field-info-container">
                    <div class="field-name">Engine Hours</div>
                    <div class="field-value">{{n-a @resource.meta.completion_data.engine_hours}}</div>
                </div>

                <div class="col-span-3 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3 mb-1">
                    Cost Breakdown
                </div>
                <div class="field-info-container">
                    <div class="field-name">Labour Cost</div>
                    <div class="field-value">
                        {{format-currency @resource.meta.completion_data.labor_cost @resource.meta.completion_data.currency}}
                    </div>
                </div>
                <div class="field-info-container">
                    <div class="field-name">Parts Cost</div>
                    <div class="field-value">
                        {{format-currency @resource.meta.completion_data.parts_cost @resource.meta.completion_data.currency}}
                    </div>
                </div>
                <div class="field-info-container">
                    <div class="field-name">Tax</div>
                    <div class="field-value">
                        {{format-currency @resource.meta.completion_data.tax @resource.meta.completion_data.currency}}
                    </div>
                </div>
                <div class="field-info-container col-span-3 border-t border-gray-200 dark:border-gray-700 pt-2 mt-1">
                    <div class="field-name font-semibold">Total Cost</div>
                    <div class="field-value font-semibold text-base">
                        {{format-currency @resource.meta.completion_data.total_cost @resource.meta.completion_data.currency}}
                    </div>
                </div>

                {{#if @resource.meta.completion_data.notes}}
                    <div class="field-info-container col-span-3 mt-2">
                        <div class="field-name">Completion Notes</div>
                        <div class="field-value whitespace-pre-wrap">{{@resource.meta.completion_data.notes}}</div>
                    </div>
                {{/if}}
            </div>
        </ContentPanel>
    {{/if}}

    <CustomField::Yield @subject={{@resource}} @viewMode={{true}} @wrapperClass="bordered-top" />
</div>
