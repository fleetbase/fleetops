{{! Orchestrator::OrderPool — left panel of the workbench }}
<div class="order-pool flex flex-col h-full overflow-hidden">

    {{! Search + count }}
    <div class="px-3 py-2 border-b dark:border-gray-700 flex items-center space-x-2 flex-shrink-0">
        <div class="relative flex-1">
            <span class="absolute inset-y-0 left-0 flex items-center justify-center pointer-events-none text-gray-400" style="width:2rem;">
                <FaIcon @icon="magnifying-glass" @size="xs" style="vertical-align:0;display:block;" />
            </span>
            <input
                type="text"
                class="form-input form-input-sm w-full pl-7i"
                placeholder={{t "orchestrator.search-orders"}}
                value={{this.orderSearch}}
                {{on "input" this.onSearchInput}}
            />
        </div>
        <span class="text-xs text-gray-400 flex-shrink-0 tabular-nums">
            {{this.filteredOrders.length}}/{{@orders.length}}
        </span>
    </div>

    {{! Filter chips }}
    <div class="px-3 py-1.5 border-b dark:border-gray-700 flex items-center space-x-1 overflow-x-auto flex-shrink-0">
        <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'all') 'active'}}" {{on "click" (fn this.setFilter "all")}}>{{t "orchestrator.filter-all"}}</button>
        <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'scheduled') 'active'}}" {{on "click" (fn this.setFilter "scheduled")}}>{{t "orchestrator.filter-scheduled"}}</button>
        <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'urgent') 'active'}}" {{on "click" (fn this.setFilter "urgent")}}>{{t "orchestrator.filter-urgent"}}</button>
        <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'imported') 'active'}}" {{on "click" (fn this.setFilter "imported")}}>{{t "orchestrator.filter-imported"}}</button>
        <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'unplanned') 'active'}}" {{on "click" (fn this.setFilter "unplanned")}}>{{t "orchestrator.filter-unplanned"}}</button>
    </div>

    {{! Order list }}
    <div class="flex-1 overflow-y-auto">
        {{#if @isLoading}}
            <div class="flex justify-center py-8"><Spinner /></div>
        {{else if this.filteredOrders.length}}
            {{#each this.filteredOrders as |order|}}
                {{! ── Order Pool Card — matches original order-pool-card style ── }}
                <div
                    class="order-pool-card mx-2 my-1 rounded border overflow-hidden cursor-grab select-none dark:border-gray-600
                        {{if (includes order.public_id this.selectedOrderIdsArray) 'ring-2 ring-indigo-500 border-indigo-400 dark:border-indigo-500' ''}}"
                    draggable="true"
                    data-order-id={{order.public_id}}
                    {{on "dragstart" (fn @onDragStart order)}}
                    {{on "click" (fn @onToggleSelection order)}}
                >
                    {{! Header: tracking number + status badge }}
                    <div class="flex items-center gap-1.5 px-2 py-1.5 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
                        <input
                            type="checkbox"
                            class="form-checkbox h-3.5 w-3.5 rounded text-indigo-600 border-gray-300 dark:border-gray-600 cursor-pointer flex-shrink-0"
                            checked={{includes order.public_id this.selectedOrderIdsArray}}
                            {{on "change" (fn @onToggleSelection order)}}
                            {{on "click" this.stopPropagation}}
                        />
                        <span class="flex-1 min-w-0 truncate text-xs font-semibold text-gray-800 dark:text-gray-100">
                            {{or order.tracking order.public_id}}
                        </span>
                        <div class="flex-shrink-0 flex items-center gap-1">
                            {{#if order.orchestrator_priority}}
                                <Badge @status={{this.priorityBadgeStatus}}>{{smart-humanize order.orchestrator_priority}}</Badge>
                            {{/if}}
                            <Badge @status={{order.status}} />
                        </div>
                    </div>
                    {{! Card body: standard fields in original dl grid style }}
                    <div class="bg-white dark:bg-gray-900 px-2 py-1.5">
                        <dl class="grid grid-cols-[auto_1fr] gap-x-2 gap-y-0.5">
                            {{! Pickup — only when present }}
                            {{#if order.payload.pickup.address}}
                                <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                    <FaIcon @icon="location-crosshairs" @size="xs" class="w-3 text-center text-green-400" />
                                    {{t "orchestrator.pickup"}}
                                </dt>
                                <dd class="truncate text-right text-gray-700 dark:text-gray-300 text-xs">{{order.payload.pickup.address}}</dd>
                            {{/if}}
                            {{! Dropoff }}
                            {{#if order.payload.dropoff.address}}
                                <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                    <FaIcon @icon="location-dot" @size="xs" class="w-3 text-center text-red-400" />
                                    {{t "orchestrator.dropoff"}}
                                </dt>
                                <dd class="truncate text-right text-gray-700 dark:text-gray-300 text-xs">{{order.payload.dropoff.address}}</dd>
                            {{/if}}
                            {{! Scheduled date }}
                            {{#if order.scheduled_at}}
                                <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                    <FaIcon @icon="clock" @size="xs" class="w-3 text-center" />
                                    {{t "orchestrator.scheduled"}}
                                </dt>
                                <dd class="truncate text-right text-blue-500 dark:text-blue-400 text-xs">{{format-date order.scheduled_at "MMM d, HH:mm"}}</dd>
                            {{/if}}
                            {{! Customer }}
                            {{#if order.customer.name}}
                                <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                    <FaIcon @icon="user" @size="xs" class="w-3 text-center" />
                                    {{t "orchestrator.customer"}}
                                </dt>
                                <dd class="truncate text-right text-gray-700 dark:text-gray-300 text-xs">{{order.customer.name}}</dd>
                            {{/if}}
                            {{! Driver assigned }}
                            <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                <FaIcon @icon="id-badge" @size="xs" class="w-3 text-center" />
                                {{t "orchestrator.driver-assigned"}}
                            </dt>
                            <dd class="truncate text-right text-gray-700 dark:text-gray-300 text-xs">{{or order.driver_assigned.name "-"}}</dd>
                            {{! Vehicle assigned }}
                            <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                <FaIcon @icon="truck" @size="xs" class="w-3 text-center" />
                                {{t "orchestrator.vehicle-assigned"}}
                            </dt>
                            <dd class="truncate text-right text-gray-700 dark:text-gray-300 text-xs">{{or order.vehicle_assigned.display_name "-"}}</dd>
                            {{! Created date }}
                            <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                <FaIcon @icon="calendar-plus" @size="xs" class="w-3 text-center" />
                                {{t "orchestrator.created"}}
                            </dt>
                            <dd class="truncate text-right text-gray-500 dark:text-gray-400 text-xs">
                                {{#if order.created_at}}{{format-date order.created_at "MMM d, HH:mm"}}{{else}}-{{/if}}
                            </dd>
                            {{! Configured custom/meta fields for this order's config — uses getter, not method call }}
                            {{#each (this.resolvedCardFields order) as |field|}}
                                <dt class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap truncate">{{field.label}}</dt>
                                <dd class="truncate text-right text-gray-700 dark:text-gray-300 text-xs">{{field.value}}</dd>
                            {{/each}}
                        </dl>
                        {{! Skills tags }}
                        {{#if order.required_skills.length}}
                            <div class="flex flex-wrap gap-0.5 mt-1">
                                {{#each order.required_skills as |skill|}}
                                    <span class="skill-tag">{{skill}}</span>
                                {{/each}}
                            </div>
                        {{/if}}
                    </div>
                </div>
            {{/each}}
        {{else}}
            <div class="flex flex-col items-center justify-center py-12 text-gray-400 text-xs">
                <FaIcon @icon="check-circle" @size="2x" class="mb-2 text-green-400" />
                {{t "orchestrator.no-unassigned-orders"}}
            </div>
        {{/if}}
    </div>

    {{! Bulk action bar + import }}
    <div class="px-3 py-2 border-t dark:border-gray-700 flex items-center justify-between flex-shrink-0">
        <Button @icon="file-import" @text={{t "orchestrator.import-orders"}} @type="default" @size="xs" @onClick={{@onOpenImport}} />
        {{#if this.selectedOrderIdsArray.length}}
            <div class="flex items-center gap-1.5">
                <span class="text-xs text-blue-400">
                    {{this.selectedOrderIdsArray.length}} {{t "orchestrator.selected"}}
                </span>
                <button type="button" class="text-xs text-gray-400 hover:text-white" {{on "click" @onClearSelection}}>
                    {{t "orchestrator.clear-selection"}}
                </button>
            </div>
        {{/if}}
    </div>
</div>
