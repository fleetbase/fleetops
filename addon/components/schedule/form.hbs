<div class="schedule-form" ...attributes>

    {{! ===== IDENTIFICATION ===== }}
    <ContentPanel @title="Schedule Details" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">

            <InputGroup @name="Schedule Name" @wrapperClass="col-span-2">
                <Input
                    @value={{@resource.name}}
                    @type="text"
                    class="w-full form-input"
                    placeholder="e.g. Oil & Filter Change — Truck #4"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

            <InputGroup @name="Type">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.typeOptions}}
                        @selected={{@resource.type}}
                        @onChange={{fn (mut @resource.type)}}
                        @placeholder="Select Type"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |type|
                    >
                        {{smart-humanize type}}
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @name="Status">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.statusOptions}}
                        @selected={{@resource.status}}
                        @onChange={{fn (mut @resource.status)}}
                        @placeholder="Select Status"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |status|
                    >
                        {{smart-humanize status}}
                    </PowerSelect>
                </div>
            </InputGroup>

        </div>
    </ContentPanel>

    {{! ===== ASSET (SUBJECT) ===== }}
    <ContentPanel @title="Asset" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Which asset does this schedule apply to?
            </div>

            <InputGroup @name="Asset Type">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.subjectTypeOptions}}
                        @selected={{this.selectedSubjectType}}
                        @onChange={{this.onSubjectTypeChange}}
                        @placeholder="Select Asset Type"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |option|
                    >
                        {{option.label}}
                    </PowerSelect>
                </div>
            </InputGroup>

            {{#if this.subjectModelName}}
                <InputGroup @name="Asset">
                    <ModelSelect
                        @modelName={{this.subjectModelName}}
                        @selected={{@resource.subject}}
                        @placeholder="Select Asset"
                        @triggerClass="form-select form-input"
                        @onChange={{this.assignSubject}}
                        @disabled={{cannot-write @resource}}
                    />
                </InputGroup>
            {{/if}}

        </div>
    </ContentPanel>

    {{! ===== INTERVAL ===== }}
    <ContentPanel @title="Maintenance Interval" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Time-Based Interval
            </div>

            <InputGroup @name="Every (Value)">
                <Input
                    @value={{@resource.interval_value}}
                    @type="number"
                    class="w-full form-input"
                    placeholder="e.g. 3"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

            <InputGroup @name="Unit">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.intervalUnitOptions}}
                        @selected={{@resource.interval_unit}}
                        @onChange={{fn (mut @resource.interval_unit)}}
                        @placeholder="Select Unit"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |unit|
                    >
                        {{smart-humanize unit}}
                    </PowerSelect>
                </div>
            </InputGroup>

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Distance-Based Interval
            </div>

            <InputGroup @name="Every (km)">
                <Input
                    @value={{@resource.interval_distance}}
                    @type="number"
                    class="w-full form-input"
                    placeholder="e.g. 5000"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

            <InputGroup @name="Every (Engine Hours)">
                <Input
                    @value={{@resource.interval_engine_hours}}
                    @type="number"
                    class="w-full form-input"
                    placeholder="e.g. 250"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Next Due Thresholds (override computed values)
            </div>

            <InputGroup @name="Next Due Date">
                <DateTimeInput
                    @value={{@resource.next_due_date}}
                    @onChange={{fn (mut @resource.next_due_date)}}
                    @disabled={{cannot-write @resource}}
                    class="w-full"
                />
            </InputGroup>

            <InputGroup @name="Next Due Odometer (km)">
                <Input
                    @value={{@resource.next_due_odometer}}
                    @type="number"
                    class="w-full form-input"
                    placeholder="e.g. 47000"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

        </div>
    </ContentPanel>

    {{! ===== WORK ORDER DEFAULTS ===== }}
    <ContentPanel @title="Work Order Defaults" @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                These settings are used when a work order is auto-generated from this schedule.
            </div>

            <InputGroup @name="Default Priority">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.priorityOptions}}
                        @selected={{@resource.default_priority}}
                        @onChange={{fn (mut @resource.default_priority)}}
                        @placeholder="Select Priority"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |priority|
                    >
                        {{smart-humanize priority}}
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @name="Default Assignee Type">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.assigneeTypeOptions}}
                        @selected={{this.selectedAssigneeType}}
                        @onChange={{this.onAssigneeTypeChange}}
                        @placeholder="Select Assignee Type"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |option|
                    >
                        {{option.label}}
                    </PowerSelect>
                </div>
            </InputGroup>

            {{#if this.assigneeModelName}}
                <InputGroup @name="Default Assignee" @wrapperClass="col-span-2">
                    <ModelSelect
                        @modelName={{this.assigneeModelName}}
                        @selected={{@resource.defaultAssignee}}
                        @placeholder="Select Default Assignee"
                        @triggerClass="form-select form-input"
                        @onChange={{this.assignDefaultAssignee}}
                        @disabled={{cannot-write @resource}}
                    />
                </InputGroup>
            {{/if}}

            <InputGroup @name="Instructions" @wrapperClass="col-span-2">
                <Textarea
                    @value={{@resource.instructions}}
                    class="w-full form-input"
                    rows="3"
                    placeholder="Instructions for the technician performing this maintenance..."
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

        </div>
    </ContentPanel>

</div>
