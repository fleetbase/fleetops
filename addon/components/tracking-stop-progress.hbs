<div class="rounded-md border border-gray-200 bg-gray-50 px-3 py-3 dark:border-gray-700 dark:bg-gray-900" ...attributes>
    <div class="mb-3 flex items-center justify-between">
        <div class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Route Progress</div>
        <div class="text-xs text-gray-500 dark:text-gray-400">
            <span class="font-semibold text-gray-800 dark:text-gray-100">{{this.completedCount}}</span>
            /
            {{this.totalCount}}
            stops
        </div>
    </div>

    <div class="overflow-x-auto pb-1">
        <div class="flex min-w-full items-start">
            {{#each this.stops as |stop|}}
                <div class="flex min-w-14 flex-1 flex-col items-center">
                    <div class="flex w-full items-center">
                        {{#if stop.isFirst}}
                            <div class="flex-1"></div>
                        {{else}}
                            <div class="h-px flex-1 border-t border-dashed border-gray-300 dark:border-gray-600"></div>
                        {{/if}}

                        <div
                            class="{{if stop.completed 'bg-green-500 text-white border-green-500'}}
                                {{if stop.active 'bg-yellow-400 text-yellow-950 border-yellow-400 shadow-sm'}}
                                {{if stop.pending 'bg-gray-100 text-gray-500 border-gray-300 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600'}}
                                relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border text-[10px] font-semibold"
                            title={{stop.title}}
                        >
                            {{stop.label}}
                        </div>

                        {{#if stop.isLast}}
                            <div class="flex-1"></div>
                        {{else}}
                            <div class="h-px flex-1 border-t border-dashed border-gray-300 dark:border-gray-600"></div>
                        {{/if}}
                    </div>

                    <div
                        class="{{if stop.active 'text-yellow-600 dark:text-yellow-300 font-semibold' 'text-gray-500 dark:text-gray-400'}}
                            mt-1 max-w-20 truncate text-center text-[10px] leading-4"
                        title={{stop.locationLabel}}
                    >
                        {{stop.locationLabel}}
                    </div>
                </div>
            {{/each}}
        </div>
    </div>
</div>