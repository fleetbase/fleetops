{{! Orchestrator Workbench — Intelligent Order Allocation & Route Optimization }}
<div class="orchestrator-workbench flex flex-col h-full overflow-hidden">

    {{! ── Toolbar (Layout::Section::Header) ── }}
    <Layout::Section::Header @title={{t "orchestrator.workbench-title"}}>
        <div class="flex items-center space-x-2">
            {{! Status badges }}
            {{#if this.hasProposedPlan}}
                <Badge @status="info">{{t "orchestrator.plan-ready"}}</Badge>
            {{/if}}
            {{#if this.isCommitted}}
                <Badge @status="success">{{t "orchestrator.committed"}}</Badge>
            {{/if}}
            {{#if this.hasUnassigned}}
                <Badge @status="warning">{{t "orchestrator.unassigned-count"}} {{this.unassignedAfterRun.length}}</Badge>
            {{/if}}

            {{#if (or this.hasProposedPlan this.isCommitted this.hasUnassigned)}}
                <div class="w-px h-5 bg-gray-300 dark:bg-gray-600 mx-1"></div>
            {{/if}}

            {{! Import orders }}
            <Button @icon="file-import" @text={{t "orchestrator.import-orders"}} @type="default" @size="sm" @onClick={{this.openImportModal}} />

            {{! Options toggle }}
            <Button @icon="sliders-h" @text={{t "orchestrator.options"}} @type={{if this.showOptionsPanel "primary" "default"}} @size="sm" @onClick={{this.toggleOptionsPanel}} />

            <div class="w-px h-5 bg-gray-300 dark:bg-gray-600 mx-1"></div>

            {{! Commit / Discard / Run }}
            {{#if this.hasProposedPlan}}
                <Button @icon="check" @text={{t "orchestrator.commit-plan"}} @type="success" @size="sm" @isLoading={{this.commitPlan.isRunning}} @onClick={{perform this.commitPlan}} />
                <Button @icon="times" @text={{t "orchestrator.discard-plan"}} @type="default" @size="sm" @onClick={{this.discardPlan}} />
            {{else}}
                <Button
                    @icon="bolt"
                    @text={{t "orchestrator.run-orchestration"}}
                    @type="primary"
                    @size="sm"
                    @isLoading={{this.runOrchestration.isRunning}}
                    @onClick={{perform this.runOrchestration}}
                />
            {{/if}}

            {{! Refresh }}
            <Button @icon="sync" @type="default" @size="sm" @isLoading={{this.loadData.isRunning}} @onClick={{perform this.loadData}} />
        </div>
    </Layout::Section::Header>

    {{! ── Run message alert banner (dismissable) ── }}
    {{#if this.orchestratorRunMessage}}
        <div class="flex items-start gap-2 px-4 py-2 bg-amber-50 dark:bg-amber-900/20 border-b border-amber-200 dark:border-amber-700 flex-shrink-0">
            <FaIcon @icon="exclamation-triangle" class="mt-0.5 flex-shrink-0 text-amber-500" @size="sm" />
            <p class="flex-1 text-xs text-amber-800 dark:text-amber-200">{{this.orchestratorRunMessage}}</p>
            <button
                type="button"
                class="flex-shrink-0 text-amber-400 hover:text-amber-600 dark:hover:text-amber-200 transition-colors"
                {{on "click" this.dismissRunMessage}}
                aria-label="Dismiss"
            >
                <FaIcon @icon="times" @size="xs" />
            </button>
        </div>
    {{/if}}

    {{! ── Options Panel (collapsible, sits below the toolbar) ── }}
    {{#if this.showOptionsPanel}}
        <div class="workbench-options-panel flex items-center flex-wrap gap-x-3 gap-y-2 px-4 py-2 border-b dark:border-gray-700 bg-gray-50 dark:bg-gray-800 flex-shrink-0">
            {{! Mode }}
            <div class="flex items-center space-x-2">
                <label class="text-xs dark:text-gray-400 whitespace-nowrap">{{t "orchestrator.mode"}}</label>
                <Select @value={{this.selectedMode}} @options={{this.modeOptions}} @optionLabel="label" @optionValue="value" @onSelect={{this.setMode}} class="form-input-sm" />
            </div>
            {{! Engine }}
            <div class="flex items-center space-x-2">
                <label class="text-xs dark:text-gray-400 whitespace-nowrap">{{t "orchestrator.engine"}}</label>
                <Select @value={{this.selectedEngine}} @options={{this.availableEngines}} @optionLabel="name" @optionValue="id" @onSelect={{this.setEngine}} class="form-input-sm" />
            </div>
            {{! Constraint toggles }}
            <div class="flex items-center space-x-1">
                <Toggle @isToggled={{this.balanceWorkload}} @onToggle={{fn (mut this.balanceWorkload)}} />
                <label class="text-xs dark:text-gray-400 whitespace-nowrap">{{t "orchestrator.balance-workload"}}</label>
            </div>
            <div class="flex items-center space-x-1">
                <Toggle @isToggled={{this.respectSkills}} @onToggle={{fn (mut this.respectSkills)}} />
                <label class="text-xs dark:text-gray-400 whitespace-nowrap">{{t "orchestrator.respect-skills"}}</label>
            </div>
            <div class="flex items-center space-x-1">
                <Toggle @isToggled={{this.respectCapacity}} @onToggle={{fn (mut this.respectCapacity)}} />
                <label class="text-xs dark:text-gray-400 whitespace-nowrap">{{t "orchestrator.respect-capacity"}}</label>
            </div>
            <div class="flex items-center space-x-1">
                <Toggle @isToggled={{this.returnToDepot}} @onToggle={{fn (mut this.returnToDepot)}} />
                <label class="text-xs dark:text-gray-400 whitespace-nowrap">{{t "orchestrator.return-to-depot"}}</label>
            </div>
        </div>
    {{/if}}

    {{! ── Main 3-Panel Body ── }}
    <div class="workbench-body flex flex-1 overflow-hidden">

        {{! ── LEFT PANEL: Order Pool ── }}
        <div
            class="order-pool flex flex-col border-r dark:border-gray-700 bg-white dark:bg-gray-900 transition-all duration-200
                {{if this.leftPanelCollapsed 'w-0 overflow-hidden' 'w-72 min-w-72'}}"
        >
            {{! Order pool header: search + count }}
            <div class="px-3 py-2 border-b dark:border-gray-700 flex items-center space-x-2 flex-shrink-0">
                <div class="relative flex-1">
                    <span class="absolute inset-y-0 left-0 flex items-center justify-center pointer-events-none text-gray-400" style="width:2rem;">
                        <FaIcon @icon="magnifying-glass" @size="xs" style="vertical-align:0;display:block;" />
                    </span>
                    <input
                        type="text"
                        class="form-input form-input-sm w-full pl-8"
                        placeholder={{t "orchestrator.search-orders"}}
                        value={{this.orderSearch}}
                        {{on "input" this.onOrderSearchInput}}
                    />
                </div>
                <span class="text-xs text-gray-400 flex-shrink-0 tabular-nums">
                    {{this.filteredOrders.length}}/{{this.unassignedOrders.length}}
                </span>
            </div>

            {{! Filter chips }}
            <div class="px-3 py-1.5 border-b dark:border-gray-700 flex items-center space-x-1 overflow-x-auto flex-shrink-0">
                <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'all') 'active'}}" {{on "click" (fn this.setOrderFilter "all")}}>{{t
                        "orchestrator.filter-all"
                    }}</button>
                <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'scheduled') 'active'}}" {{on "click" (fn this.setOrderFilter "scheduled")}}>{{t
                        "orchestrator.filter-scheduled"
                    }}</button>
                <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'urgent') 'active'}}" {{on "click" (fn this.setOrderFilter "urgent")}}>{{t
                        "orchestrator.filter-urgent"
                    }}</button>
                <button type="button" class="order-filter-chip {{if (eq this.orderFilter 'imported') 'active'}}" {{on "click" (fn this.setOrderFilter "imported")}}>{{t
                        "orchestrator.filter-imported"
                    }}</button>
            </div>

            {{! Order list }}
            <div class="flex-1 overflow-y-auto">
                {{#if this.loadData.isRunning}}
                    <div class="flex justify-center py-8"><Spinner /></div>
                {{else if this.filteredOrders.length}}
                    {{#each this.filteredOrders as |order|}}
                        {{! ── Order Pool Card — modelled on Order::ScheduleCard ── }}
                        <div
                            class="order-pool-card mx-2 my-1 rounded border overflow-hidden cursor-grab select-none dark:border-gray-600
                                {{if (includes order.public_id this.selectedOrderIdsArray) 'ring-2 ring-indigo-500 border-indigo-400 dark:border-indigo-500' ''}}"
                            draggable="true"
                            data-order-id={{order.public_id}}
                            {{on "dragstart" (fn this.onOrderDragStart order)}}
                            {{on "click" (fn this.toggleOrderSelection order)}}
                        >
                            {{! Header: tracking number + status badge }}
                            <div class="flex items-center gap-1.5 px-2 py-1.5 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
                                <input
                                    type="checkbox"
                                    class="form-checkbox h-3.5 w-3.5 rounded text-indigo-600 border-gray-300 dark:border-gray-600 cursor-pointer flex-shrink-0"
                                    checked={{includes order.public_id this.selectedOrderIdsArray}}
                                    {{on "click" (fn this.toggleOrderSelection order)}}
                                />
                                <span class="flex-1 min-w-0 truncate text-xs font-semibold text-gray-800 dark:text-gray-100">
                                    {{or order.tracking order.public_id}}
                                </span>
                                <div class="flex-shrink-0 flex items-center gap-1">
                                    {{#if order.orchestrator_priority}}
                                        <Badge @status={{this.priorityStatus order.orchestrator_priority}}>{{smart-humanize order.orchestrator_priority}}</Badge>
                                    {{/if}}
                                    <Badge @status={{order.status}} />
                                </div>
                            </div>

                            {{! Body: 2-column dl grid — all fields always shown, "-" when absent }}
                            <div class="bg-white dark:bg-gray-900 px-2 py-1.5">
                                <dl class="grid grid-cols-[auto_1fr] gap-x-2 gap-y-0.5 text-xs">
                                    {{! Pickup }}
                                    <dt class="flex items-center gap-1 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                        <FaIcon @icon="circle-dot" @size="xs" class="w-3 text-center text-green-500" />
                                        {{t "orchestrator.pickup"}}
                                    </dt>
                                    <dd class="truncate text-right text-gray-700 dark:text-gray-300">
                                        {{or order.payload.pickup.address "-"}}
                                    </dd>
                                    {{! Dropoff }}
                                    <dt class="flex items-center gap-1 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                        <FaIcon @icon="location-dot" @size="xs" class="w-3 text-center text-red-400" />
                                        {{t "orchestrator.dropoff"}}
                                    </dt>
                                    <dd class="truncate text-right text-gray-700 dark:text-gray-300">
                                        {{or order.payload.dropoff.address "-"}}
                                    </dd>
                                    {{! Scheduled date }}
                                    <dt class="flex items-center gap-1 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                        <FaIcon @icon="clock" @size="xs" class="w-3 text-center" />
                                        {{t "orchestrator.scheduled"}}
                                    </dt>
                                    <dd class="truncate text-right text-blue-500 dark:text-blue-400">
                                        {{#if order.scheduled_at}}
                                            {{format-date order.scheduled_at "MMM d, HH:mm"}}
                                        {{else}}
                                            -
                                        {{/if}}
                                    </dd>
                                    {{! Customer }}
                                    <dt class="flex items-center gap-1 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                        <FaIcon @icon="user" @size="xs" class="w-3 text-center" />
                                        {{t "orchestrator.customer"}}
                                    </dt>
                                    <dd class="truncate text-right text-gray-700 dark:text-gray-300">
                                        {{or order.customer.name "-"}}
                                    </dd>
                                    {{! Driver assigned }}
                                    <dt class="flex items-center gap-1 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                        <FaIcon @icon="id-badge" @size="xs" class="w-3 text-center" />
                                        {{t "orchestrator.driver-assigned"}}
                                    </dt>
                                    <dd class="truncate text-right text-gray-700 dark:text-gray-300">
                                        {{or order.driver_assigned.name "-"}}
                                    </dd>
                                    {{! Vehicle assigned }}
                                    <dt class="flex items-center gap-1 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                                        <FaIcon @icon="truck" @size="xs" class="w-3 text-center" />
                                        {{t "orchestrator.vehicle-assigned"}}
                                    </dt>
                                    <dd class="truncate text-right text-gray-700 dark:text-gray-300">
                                        {{or order.vehicle_assigned.display_name "-"}}
                                    </dd>
                                </dl>
                                {{! Skills tags — additive, only shown when present }}
                                {{#if order.required_skills.length}}
                                    <div class="flex flex-wrap gap-0.5 mt-1">
                                        {{#each order.required_skills as |skill|}}
                                            <span class="skill-tag">{{skill}}</span>
                                        {{/each}}
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                    {{/each}}
                {{else}}
                    <div class="flex flex-col items-center justify-center py-12 text-gray-400 text-xs">
                        <FaIcon @icon="check-circle" @size="2x" class="mb-2 text-green-400" />
                        {{t "orchestrator.no-unassigned-orders"}}
                    </div>
                {{/if}}
            </div>

            {{! Bulk action bar (shown when orders selected) }}
            {{#if this.selectedOrders.length}}
                <div class="px-3 py-2 border-t dark:border-gray-700 bg-blue-900/20 flex items-center justify-between flex-shrink-0">
                    <span class="text-xs text-blue-400">
                        {{this.selectedOrders.length}}
                        {{t "orchestrator.selected"}}
                    </span>
                    <button type="button" class="text-xs text-gray-400 hover:text-white" {{on "click" this.clearSelection}}>
                        {{t "orchestrator.clear-selection"}}
                    </button>
                </div>
            {{/if}}
        </div>

        {{! ── Left panel collapse toggle ── }}
        <button
            type="button"
            class="workbench-panel-toggle flex items-center justify-center w-4 bg-gray-100 dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors flex-shrink-0"
            title={{if this.leftPanelCollapsed (t "orchestrator.show-orders") (t "orchestrator.hide-orders")}}
            {{on "click" this.toggleLeftPanel}}
        >
            <FaIcon @icon={{if this.leftPanelCollapsed "chevron-right" "chevron-left"}} @size="xs" class="text-gray-400" />
        </button>

        {{! ── CENTRE PANEL: Map ── }}
        <div class="map-panel flex-1 relative overflow-hidden">
            <div class="next-map-container w-full h-full">
            {{#if this.mapReady}}
                <LeafletMap class="w-full h-full" @lat={{this.mapCenter.lat}} @lng={{this.mapCenter.lng}} @zoom={{this.mapZoom}} @onLoad={{this.onMapLoad}} as |layers|>
                    <layers.tile @url={{this.tileSourceUrl}} />

                    {{! Order markers — blue dot via div-icon (no broken image URL) }}
                    {{#each this.filteredOrders as |order|}}
                        {{#if order.payload.dropoff.location}}
                            <layers.marker
                                @lat={{order.payload.dropoff.location.coordinates.[1]}}
                                @lng={{order.payload.dropoff.location.coordinates.[0]}}
                                @icon={{div-icon
                                    html=(concat '<div class="orch-marker-order' (if (includes order.public_id this.selectedOrderIdsArray) " selected" "") '"></div>')
                                    className="orch-marker-wrapper"
                                    iconSize=(array 14 14)
                                    iconAnchor=(array 7 7)
                                }}
                                @draggable={{false}}
                                @riseOnHover={{true}}
                            >
                                <layers.popup>
                                    <div class="text-xs min-w-32">
                                        <div class="font-semibold mb-0.5">{{or order.tracking order.public_id}}</div>
                                        <div class="text-gray-500">{{order.payload.dropoff.address}}</div>
                                        {{#if order.scheduled_at}}
                                            <div class="text-blue-500 mt-0.5">{{format-date order.scheduled_at "MMM d, HH:mm"}}</div>
                                        {{/if}}
                                    </div>
                                </layers.popup>
                                <layers.tooltip @permanent={{false}} @sticky={{true}} @direction="top">
                                    {{or order.tracking order.public_id}}
                                </layers.tooltip>
                            </layers.marker>
                        {{/if}}
                    {{/each}}

                    {{! Driver markers — green/red dot via div-icon }}
                    {{#each this.availableDrivers as |driver|}}
                        {{#if driver.location}}
                            <layers.marker
                                @lat={{driver.location.coordinates.[1]}}
                                @lng={{driver.location.coordinates.[0]}}
                                @icon={{div-icon
                                    html=(concat '<div class="orch-marker-driver ' (if driver.online "online" "offline") '"></div>')
                                    className="orch-marker-wrapper"
                                    iconSize=(array 16 16)
                                    iconAnchor=(array 8 8)
                                }}
                                @riseOnHover={{true}}
                            >
                                <layers.popup>
                                    <div class="text-xs min-w-36">
                                        <div class="font-semibold mb-0.5">{{driver.name}}</div>
                                        {{#if driver.vehicle}}
                                            <div class="text-gray-500">{{driver.vehicle.display_name}}</div>
                                        {{/if}}
                                        <div class="mt-0.5 {{if driver.online 'text-green-500' 'text-red-400'}}">
                                            {{if driver.online (t "common.online") (t "common.offline")}}
                                        </div>
                                    </div>
                                </layers.popup>
                                <layers.tooltip @permanent={{false}} @sticky={{true}} @direction="top">
                                    {{driver.name}}
                                </layers.tooltip>
                            </layers.marker>
                        {{/if}}
                    {{/each}}

                    {{! Proposed route polylines }}
                    {{#if this.hasProposedPlan}}
                        {{#each this.planByVehicle as |group|}}
                            {{#if group.routePolyline}}
                                <layers.polyline @positions={{group.routePolyline}} @color={{group.routeColor}} @weight={{3}} @opacity={{0.8}} />
                            {{/if}}
                        {{/each}}
                    {{/if}}
                </LeafletMap>
            {{else}}
                <div class="flex items-center justify-center h-full text-gray-400">
                    <Spinner />
                </div>
            {{/if}}

            {{! Map overlay: engine running indicator }}
            {{#if this.runOrchestration.isRunning}}
                <div class="absolute inset-0 bg-gray-900/60 flex flex-col items-center justify-center z-10">
                    <Spinner @size="lg" class="mb-3" />
                    <span class="text-sm text-white">{{t "orchestrator.running"}}</span>
                </div>
            {{/if}}
        </div>

        {{! ── Right panel collapse toggle ── }}
        <button
            type="button"
            class="workbench-panel-toggle flex items-center justify-center w-4 bg-gray-100 dark:bg-gray-800 border-l border-gray-200 dark:border-gray-700 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors flex-shrink-0"
            title={{if this.rightPanelCollapsed (t "orchestrator.show-drivers") (t "orchestrator.hide-drivers")}}
            {{on "click" this.toggleRightPanel}}
        >
            <FaIcon @icon={{if this.rightPanelCollapsed "chevron-left" "chevron-right"}} @size="xs" class="text-gray-400" />
        </button>

        {{! ── RIGHT PANEL: Resources / Route Timeline ── }}
        <div
            class="driver-panel flex flex-col border-l dark:border-gray-700 bg-white dark:bg-gray-900 transition-all duration-200
                {{if this.rightPanelCollapsed 'w-0 overflow-hidden' 'w-80 min-w-80'}}"
        >
            {{! ── Plan view: per-vehicle route cards (shown after Run) ── }}
            {{#if this.hasProposedPlan}}
                <div class="px-3 py-2 border-b dark:border-gray-700 flex items-center justify-between flex-shrink-0">
                    <span class="text-xs font-medium uppercase tracking-wide dark:text-gray-400">
                        {{t "orchestrator.proposed-routes"}}
                        ({{this.planByVehicle.length}})
                    </span>
                    <button type="button" class="text-xs text-blue-400 hover:text-blue-300" {{on "click" this.discardPlan}}>
                        {{t "orchestrator.clear"}}
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto">
                    {{#if this.hasUnassigned}}
                        <div class="mx-3 mt-2 px-3 py-2 rounded bg-yellow-900/30 border border-yellow-700 text-yellow-400 text-xs">
                            <FaIcon @icon="exclamation-triangle" class="mr-1" />
                            {{t "orchestrator.unassigned-warning" count=this.unassignedAfterRun.length}}
                        </div>
                    {{/if}}
                    {{#each this.planByVehicle as |group|}}
                        <div class="vehicle-route-card mx-3 my-2 rounded border dark:border-gray-600 dark:bg-gray-800 overflow-hidden" data-vehicle-id={{group.vehicle.public_id}}>
                            {{! Vehicle / driver header — click to expand/collapse }}
                            <div
                                class="flex items-center px-3 py-2 border-b dark:border-gray-700 cursor-pointer"
                                style="border-left: 3px solid {{group.routeColor}}"
                                {{on "click" (fn this.toggleRouteCard group.vehicle.public_id)}}
                            >
                                <FaIcon @icon="truck" class="mr-2 text-blue-400 flex-shrink-0" />
                                <div class="flex-1 min-w-0">
                                    <div class="text-xs font-semibold dark:text-white truncate">{{group.vehicle.display_name}}</div>
                                    {{#if group.driver}}
                                        <div class="text-xs text-gray-400 truncate">{{group.driver.name}}</div>
                                    {{/if}}
                                </div>
                                <div class="flex items-center space-x-1 flex-shrink-0">
                                    <span class="text-xs text-gray-400">{{group.orders.length}} {{t "orchestrator.stops"}}</span>
                                    {{#if group.summary.duration}}
                                        <span class="text-xs text-gray-500">·</span>
                                        <span class="text-xs text-gray-400">{{this.formatDuration group.summary.duration}}</span>
                                    {{/if}}
                                    <FaIcon @icon={{if (includes group.vehicle.public_id this.expandedRouteCardsArray) "chevron-up" "chevron-down"}} @size="xs" class="text-gray-500 ml-1" />
                                </div>
                            </div>

                            {{! Expanded stop list — drag target for resequencing }}
                            {{#if (includes group.vehicle.public_id this.expandedRouteCardsArray)}}
                                <div
                                    class="vehicle-drop-zone px-2 py-1"
                                    data-vehicle-id={{group.vehicle.public_id}}
                                    data-driver-id={{group.driver.public_id}}
                                    {{on "dragover" this.onDragOver}}
                                    {{on "drop" (fn this.onDropOnVehicle group.vehicle.public_id group.driver.public_id)}}
                                >
                                    {{#each group.orders as |item|}}
                                        <div
                                            class="assigned-stop flex items-center px-2 py-1.5 my-0.5 rounded text-xs cursor-grab
                                                {{if item._overridden 'border border-dashed border-orange-500 bg-orange-900/20' 'dark:bg-gray-700'}}"
                                            draggable="true"
                                            data-order-id={{item.order.public_id}}
                                            {{on "dragstart" (fn this.onAssignedOrderDragStart item.order)}}
                                        >
                                            <span class="w-5 text-center text-gray-500 mr-2 flex-shrink-0 tabular-nums">{{item.sequence}}</span>
                                            <div class="flex-1 min-w-0">
                                                <div class="dark:text-white truncate font-medium">{{or item.order.tracking item.order.public_id}}</div>
                                                <div class="text-gray-400 truncate">{{item.order.payload.dropoff.address}}</div>
                                            </div>
                                            {{#if item.arrival}}
                                                <span class="text-gray-500 text-xs flex-shrink-0 ml-1 tabular-nums">{{this.formatUnixTime item.arrival}}</span>
                                            {{/if}}
                                            {{#if item._overridden}}
                                                <FaIcon @icon="pen" @size="xs" class="text-orange-400 ml-1 flex-shrink-0" />
                                            {{/if}}
                                        </div>
                                    {{/each}}
                                    {{! Drop placeholder when empty }}
                                    {{#unless group.orders.length}}
                                        <div class="py-3 text-center text-xs text-gray-500">
                                            {{t "orchestrator.drop-orders-here"}}
                                        </div>
                                    {{/unless}}
                                </div>

                                {{! Route summary footer }}
                                {{#if (or group.summary.distance group.summary.duration)}}
                                    <div class="px-3 py-1.5 border-t dark:border-gray-700 flex items-center space-x-3 text-xs text-gray-500">
                                        {{#if group.summary.distance}}
                                            <span><FaIcon @icon="road" @size="xs" class="mr-0.5" />{{this.formatDistance group.summary.distance}}</span>
                                        {{/if}}
                                        {{#if group.summary.duration}}
                                            <span><FaIcon @icon="clock" @size="xs" class="mr-0.5" />{{this.formatDuration group.summary.duration}}</span>
                                        {{/if}}
                                    </div>
                                {{/if}}
                            {{/if}}
                        </div>
                    {{/each}}
                </div>

                {{! ── Pre-run view: tabbed Drivers / Vehicles ── }}
            {{else}}
                {{! Tab bar }}
                <div class="flex border-b dark:border-gray-700 flex-shrink-0">
                    <button
                        type="button"
                        class="flex-1 py-2 text-xs font-medium transition-colors
                            {{if
                                (eq this.rightPanelTab 'drivers')
                                'text-indigo-500 border-b-2 border-indigo-500 dark:text-indigo-400 dark:border-indigo-400'
                                'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'
                            }}"
                        {{on "click" (fn this.setRightPanelTab "drivers")}}
                    >
                        <FaIcon @icon="id-card-alt" @size="xs" class="mr-1" />
                        {{t "orchestrator.available-drivers"}}
                        <span class="ml-1 text-gray-400 tabular-nums">({{this.availableDrivers.length}})</span>
                    </button>
                    <button
                        type="button"
                        class="flex-1 py-2 text-xs font-medium transition-colors
                            {{if
                                (eq this.rightPanelTab 'vehicles')
                                'text-indigo-500 border-b-2 border-indigo-500 dark:text-indigo-400 dark:border-indigo-400'
                                'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'
                            }}"
                        {{on "click" (fn this.setRightPanelTab "vehicles")}}
                    >
                        <FaIcon @icon="truck" @size="xs" class="mr-1" />
                        {{t "orchestrator.available-vehicles"}}
                        <span class="ml-1 text-gray-400 tabular-nums">({{this.availableVehicles.length}})</span>
                    </button>
                </div>

                {{! Tab content }}
                <div class="flex-1 overflow-y-auto">
                    {{#if this.loadData.isRunning}}
                        <div class="flex justify-center py-8"><Spinner /></div>

                        {{! ── Drivers tab ── }}
                    {{else if (eq this.rightPanelTab "drivers")}}
                        {{#if this.availableDrivers.length}}
                            {{#each this.availableDrivers as |driver|}}
                                <div
                                    role="button"
                                    class="flex items-start gap-3 px-3 py-2.5 border-b dark:border-gray-700/60 cursor-pointer select-none transition-colors
                                           {{if (includes driver.public_id this.selectedDriverIdsArray)
                                               'bg-indigo-100 dark:bg-indigo-900/60 hover:bg-indigo-100 dark:hover:bg-indigo-900/60'
                                               'hover:bg-gray-50 dark:hover:bg-gray-800/60'}}"
                                    {{on "click" (fn this.toggleDriverSelection driver)}}
                                >
                                    {{! Avatar — online dot top-right }}
                                    <div class="relative flex-shrink-0 mt-0.5">
                                        <img
                                            src={{driver.photo_url}}
                                            alt={{or driver.name "Driver"}}
                                            class="w-9 h-9 rounded-full object-cover bg-gray-200 dark:bg-gray-700"
                                            {{fallback-img-src (config "defaultValues.driverImage")}}
                                        />
                                        <span class="absolute top-0 right-0 block w-2.5 h-2.5 rounded-full border-2 border-white dark:border-gray-900
                                                     {{if driver.online 'bg-green-500' 'bg-gray-400'}}"></span>
                                    </div>

                                    {{! All fields — always shown, "-" when absent }}
                                    <div class="flex-1 min-w-0 space-y-0.5">
                                        <div class="text-xs font-semibold truncate dark:text-white">{{or driver.name "-"}}</div>

                                        {{! Vehicle }}
                                        <div class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                                            <FaIcon @icon="truck" @size="xs" class="w-3 flex-shrink-0" />
                                            <span class="truncate">{{or driver.vehicle.display_name (t "orchestrator.no-vehicle-assigned")}}</span>
                                        </div>

                                        {{! Phone }}
                                        <div class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                                            <FaIcon @icon="phone" @size="xs" class="w-3 flex-shrink-0" />
                                            <span class="truncate">{{or driver.phone "-"}}</span>
                                        </div>

                                        {{! Email }}
                                        <div class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                                            <FaIcon @icon="envelope" @size="xs" class="w-3 flex-shrink-0" />
                                            <span class="truncate">{{or driver.email "-"}}</span>
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        {{else}}
                            <div class="flex flex-col items-center justify-center py-12 text-gray-400 text-xs">
                                <FaIcon @icon="id-card-alt" @size="2x" class="mb-2 opacity-40" />
                                {{t "orchestrator.no-available-drivers"}}
                            </div>
                        {{/if}}

                        {{! ── Vehicles tab ── }}
                    {{else if (eq this.rightPanelTab "vehicles")}}
                        {{#if this.availableVehicles.length}}
                            {{#each this.availableVehicles as |vehicle|}}
                                <div
                                    role="button"
                                    class="flex items-start gap-3 px-3 py-2.5 border-b dark:border-gray-700/60 cursor-pointer select-none transition-colors
                                           {{if (includes vehicle.public_id this.selectedVehicleIdsArray)
                                               'bg-indigo-100 dark:bg-indigo-900/60 hover:bg-indigo-100 dark:hover:bg-indigo-900/60'
                                               'hover:bg-gray-50 dark:hover:bg-gray-800/60'}}"
                                    {{on "click" (fn this.toggleVehicleSelection vehicle)}}
                                >
                                    {{! Avatar (photo_url) — driver online dot top-right }}
                                    <div class="relative flex-shrink-0 mt-0.5">
                                        <img
                                            src={{vehicle.photo_url}}
                                            alt={{or vehicle.display_name "Vehicle"}}
                                            class="w-9 h-9 rounded object-cover bg-gray-200 dark:bg-gray-700"
                                            {{fallback-img-src (config "defaultValues.vehicleAvatar")}}
                                        />
                                        <span class="absolute top-0 right-0 block w-2.5 h-2.5 rounded-full border-2 border-white dark:border-gray-900
                                                     {{if vehicle.driver.online 'bg-green-500' 'bg-gray-400'}}"></span>
                                    </div>

                                    {{! All fields — always shown, "-" when absent }}
                                    <div class="flex-1 min-w-0 space-y-0.5">
                                        {{! Name + vehicle status badge }}
                                        <div class="flex items-center gap-1.5">
                                            <span class="text-xs font-semibold truncate dark:text-white">{{or vehicle.display_name "-"}}</span>
                                            {{#if vehicle.status}}
                                                <Badge @status={{vehicle.status}}>{{smart-humanize vehicle.status}}</Badge>
                                            {{/if}}
                                        </div>

                                        {{! Assigned driver }}
                                        <div class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                                            <FaIcon @icon="id-card-alt" @size="xs" class="w-3 flex-shrink-0" />
                                            <span class="truncate">{{or vehicle.driver.name (t "orchestrator.no-driver-assigned")}}</span>
                                        </div>

                                        {{! Plate number }}
                                        <div class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                                            <FaIcon @icon="hashtag" @size="xs" class="w-3 flex-shrink-0" />
                                            <span class="truncate">{{or vehicle.plate_number "-"}}</span>
                                        </div>

                                        {{! Call sign }}
                                        <div class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                                            <FaIcon @icon="broadcast-tower" @size="xs" class="w-3 flex-shrink-0" />
                                            <span class="truncate">{{or vehicle.call_sign "-"}}</span>
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        {{else}}
                            <div class="flex flex-col items-center justify-center py-12 text-gray-400 text-xs">
                                <FaIcon @icon="truck" @size="2x" class="mb-2 opacity-40" />
                                {{t "orchestrator.no-available-vehicles"}}
                            </div>
                        {{/if}}
                    {{/if}}
                </div>

                {{! Selection info bar }}
                {{#if (or this.selectedDrivers.length this.selectedVehicles.length)}}
                    <div class="px-3 py-2 border-t dark:border-gray-700 bg-indigo-900/20 flex items-center justify-between flex-shrink-0">
                        <span class="text-xs text-indigo-400">
                            {{#if this.selectedDrivers.length}}
                                {{this.selectedDrivers.length}}
                                {{t "orchestrator.drivers-selected"}}
                            {{/if}}
                            {{#if (and this.selectedDrivers.length this.selectedVehicles.length)}}
                                ·
                            {{/if}}
                            {{#if this.selectedVehicles.length}}
                                {{this.selectedVehicles.length}}
                                vehicles selected
                            {{/if}}
                        </span>
                        <button type="button" class="text-xs text-gray-400 hover:text-white" {{on "click" (fn this.clearDriverSelection)}}>
                            {{t "orchestrator.clear-selection"}}
                        </button>
                    </div>
                {{/if}}
            {{/if}}
        </div>

    </div>
</div>