<div class="equipment-form" ...attributes>

    {{! ===== PHOTO ===== }}
    <ContentPanel @title="Photo" @open={{true}} @wrapperClass="mb-4 px-4">
        <div class="flex items-center justify-center p-4">
            <div class="flex flex-col items-center space-y-3">
                {{#if @resource.photo_url}}
                    <img src={{@resource.photo_url}} alt="Equipment Photo" class="w-24 h-24 rounded-lg object-cover border border-gray-200 dark:border-gray-700" />
                {{else}}
                    <div class="w-24 h-24 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center border border-dashed border-gray-300 dark:border-gray-600">
                        <FaIcon @icon="image" class="text-gray-400 text-3xl" />
                    </div>
                {{/if}}
                <FileUpload @name="photo" @accept="image/*" @onUpload={{this.handlePhotoUpload}} @disabled={{cannot-write @resource}}>
                    <a class="text-xs text-blue-500 hover:underline cursor-pointer">Upload Photo</a>
                </FileUpload>
                <span class="text-gray-300 dark:text-gray-600 text-xs">Supports JPG, PNG, GIF</span>
            </div>
        </div>
    </ContentPanel>

    {{! ===== IDENTIFICATION ===== }}
    <ContentPanel @title="Identification" @open={{true}} @wrapperClass="bordered-top px-4">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Equipment Details
            </div>
            <InputGroup @name="Name">
                <Input
                    @value={{@resource.name}}
                    @type="text"
                    class="w-full form-input"
                    placeholder="Equipment name"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>
            <InputGroup @name="Code">
                <Input
                    @value={{@resource.code}}
                    @type="text"
                    class="w-full form-input"
                    placeholder="Internal code or reference"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>
            <InputGroup @name="Serial Number">
                <Input
                    @value={{@resource.serial_number}}
                    @type="text"
                    class="w-full form-input"
                    placeholder="Manufacturer serial number"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>
            <InputGroup @name="Manufacturer">
                <Input
                    @value={{@resource.manufacturer}}
                    @type="text"
                    class="w-full form-input"
                    placeholder="Manufacturer name"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>
            <InputGroup @name="Model">
                <Input
                    @value={{@resource.model}}
                    @type="text"
                    class="w-full form-input"
                    placeholder="Model designation"
                    disabled={{cannot-write @resource}}
                />
            </InputGroup>

            {{! Type & Status }}
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Type & Status
            </div>
            <InputGroup @name="Type">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.equipmentTypeOptions}}
                        @selected={{@resource.type}}
                        @onChange={{fn (mut @resource.type)}}
                        @placeholder="Select Equipment Type"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |type|
                    >
                        {{smart-humanize type}}
                    </PowerSelect>
                </div>
            </InputGroup>
            <InputGroup @name="Status">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.statusOptions}}
                        @selected={{@resource.status}}
                        @onChange={{fn (mut @resource.status)}}
                        @placeholder="Select Status"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |status|
                    >
                        {{smart-humanize status}}
                    </PowerSelect>
                </div>
            </InputGroup>
        </div>
    </ContentPanel>

    {{! ===== ASSIGNMENT ===== }}
    <ContentPanel @title="Assignment" @open={{true}} @wrapperClass="bordered-top px-4">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Equipped To
            </div>
            <InputGroup @name="Asset Type">
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.equipableTypeOptions}}
                        @selected={{@resource.equipable_type}}
                        @onChange={{this.onEquipableTypeChange}}
                        @placeholder="Select asset type (Vehicle, Driver…)"
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |type|
                    >
                        {{smart-humanize type}}
                    </PowerSelect>
                </div>
            </InputGroup>
            {{#if this.equipableModelName}}
                <InputGroup @name="Asset">
                    <ModelSelect
                        @modelName={{this.equipableModelName}}
                        @selectedModel={{@resource.equipable}}
                        @placeholder="Select asset to equip on"
                        @triggerClass="form-select form-input"
                        @infiniteScroll={{false}}
                        @renderInPlace={{true}}
                        @onChange={{this.assignEquipable}}
                        @disabled={{cannot-write @resource}}
                        as |model|
                    >
                        {{or model.name model.public_id}}
                    </ModelSelect>
                </InputGroup>
            {{/if}}
        </div>
    </ContentPanel>

    {{! ===== PURCHASE & WARRANTY ===== }}
    <ContentPanel @title="Purchase & Warranty" @open={{true}} @wrapperClass="bordered-top px-4">
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">
            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                Purchase Information
            </div>
            <InputGroup @name="Purchase Price">
                <MoneyInput
                    class="w-full"
                    @value={{@resource.purchase_price}}
                    @currency={{or @resource.currency "USD"}}
                    @canSelectCurrency={{true}}
                    @onCurrencyChange={{fn (mut @resource.currency)}}
                    @disabled={{cannot-write @resource}}
                />
            </InputGroup>
            <InputGroup @name="Purchase Date">
                <DatePicker
                    @value={{or (format-date-fns @resource.purchased_at "dd-MM-yyyy") null}}
                    @onChange={{fn (mut @resource.purchased_at)}}
                    @placeholder="DD-MM-YYYY"
                    class="filter-date-input w-full flex-1"
                />
            </InputGroup>

            <div class="col-span-1 lg:col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                Warranty
            </div>
            <InputGroup @name="Warranty" @wrapperClass="col-span-2">
                <ModelSelect
                    @modelName="warranty"
                    @selectedModel={{@resource.warranty}}
                    @placeholder="Select Warranty (optional)"
                    @triggerClass="form-select form-input"
                    @infiniteScroll={{false}}
                    @renderInPlace={{true}}
                    @onChange={{fn (mut @resource.warranty)}}
                    @onChangeId={{fn (mut @resource.warranty_uuid)}}
                    @disabled={{cannot-write @resource}}
                    as |model|
                >
                    {{model.policy_number}} - {{model.provider}}
                </ModelSelect>
            </InputGroup>
        </div>
    </ContentPanel>

    {{! ===== REGISTRY & METADATA ===== }}
    <RegistryYield @registry="fleet-ops:component:equipment:form:details" as |RegistryComponent|>
        <RegistryComponent @resource={{@resource}} @controller={{@controller}} @permission={{get-write-permission @resource}} />
    </RegistryYield>
    <CustomField::Yield @subject={{@resource}} @wrapperClass="bordered-top" />
    <RegistryYield @registry="fleet-ops:component:equipment:form" as |RegistryComponent|>
        <RegistryComponent @resource={{@resource}} @controller={{@controller}} @permission={{get-write-permission @resource}} />
    </RegistryYield>
    <ContentPanel @title="Metadata" @open={{false}} @wrapperClass="bordered-top">
        <MetadataEditor @value={{@resource.meta}} @onChange={{fn (mut @resource.meta)}} />
    </ContentPanel>
</div>
