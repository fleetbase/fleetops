<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    {{! ── Step tab nav — flush to modal body top, no outer padding ── }}
    <nav class="flex border-b dark:border-gray-700">
        <div class="import-step-tab {{if (eq this.step 'upload') 'import-step-tab--active' ''}}">
            <span class="import-step-tab-num {{if (eq this.step 'upload') 'import-step-tab-num--active' ''}}">1</span>
            <span>{{t "orchestrator.import-step-upload"}}</span>
        </div>
        <div class="import-step-tab {{if (eq this.step 'map') 'import-step-tab--active' ''}}">
            <span class="import-step-tab-num {{if (eq this.step 'map') 'import-step-tab-num--active' ''}}">2</span>
            <span>{{t "orchestrator.import-step-map"}}</span>
        </div>
        <div class="import-step-tab {{if (eq this.step 'preview') 'import-step-tab--active' ''}}">
            <span class="import-step-tab-num {{if (eq this.step 'preview') 'import-step-tab-num--active' ''}}">3</span>
            <span>{{t "orchestrator.import-step-preview"}}</span>
        </div>
    </nav>

    {{! ── Step content ── }}
    <div class="px-4 py-4 grid grid-cols-1 gap-4 text-xs dark:text-gray-100">

        {{! ── Step 1: Upload ── }}
        {{#if (eq this.step "upload")}}
            {{#let (file-queue name="orchestrator-import" onFileAdded=this.onFileQueued accept=".csv,.xlsx,.xls") as |queue|}}
                <FileDropzone
                    @queue={{queue}}
                    class="import-dropzone {{if this.isDraggingFile 'dragging' ''}}"
                    as |dropzone|
                >
                    {{#if dropzone.active}}
                        {{#if dropzone.valid}}
                            <FaIcon @icon="cloud-upload-alt" @size="2x" class="text-indigo-400 mb-2" />
                            <p class="text-sm dark:text-gray-300">Drop to upload</p>
                        {{else}}
                            <FaIcon @icon="times-circle" @size="2x" class="text-red-400 mb-2" />
                            <p class="text-sm text-red-400">Invalid file type</p>
                        {{/if}}
                    {{else if this.selectedFile}}
                        <div class="flex flex-col items-center">
                            <FaIcon @icon="file-excel" @size="2x" class="text-green-400 mb-2" />
                            <span class="font-medium dark:text-white">{{this.selectedFile.name}}</span>
                            <span class="text-gray-400 mt-0.5">{{this.formattedFileSize}}</span>
                            <button type="button" class="mt-2 text-red-400 hover:text-red-300 text-xs" {{on "click" this.clearFile}}>
                                {{t "orchestrator.remove-file"}}
                            </button>
                        </div>
                    {{else}}
                        <FaIcon @icon="cloud-upload-alt" @size="2x" class="text-gray-400 mb-2" />
                        <p class="text-sm dark:text-gray-300">{{t "orchestrator.drop-file-here"}}</p>
                        <p class="text-gray-500 my-1">{{t "orchestrator.or"}}</p>
                        <UploadButton
                            @buttonText={{t "orchestrator.browse-file"}}
                            @type="default"
                            @icon="folder-open"
                            @name="orchestrator-import"
                            @for="orchestrator-import"
                            @accept=".csv,.xlsx,.xls"
                            @multiple={{false}}
                            @onFileAdded={{this.onFileQueued}}
                            class="justify-center"
                        />
                        <p class="text-gray-500 mt-2 text-xs">{{t "orchestrator.accepted-formats"}}</p>
                    {{/if}}
                </FileDropzone>
            {{/let}}

            {{! Template download }}
            <div class="flex items-center justify-between px-3 py-2 rounded dark:bg-gray-800 border dark:border-gray-700">
                <div>
                    <p class="font-medium dark:text-gray-200">{{t "orchestrator.download-template"}}</p>
                    <p class="text-gray-500">{{t "orchestrator.download-template-desc"}}</p>
                </div>
                <Button
                    @icon="download"
                    @text={{t "orchestrator.download"}}
                    @type="default"
                    @size="sm"
                    {{on "click" this.downloadTemplate}}
                />
            </div>

            {{#if this.parseError}}
                <div class="px-3 py-2 rounded bg-red-900/30 border border-red-700 text-red-400">
                    <FaIcon @icon="exclamation-circle" class="mr-1" />
                    {{this.parseError}}
                </div>
            {{/if}}
        {{/if}}

        {{! ── Step 2: Column Mapping ── }}
        {{#if (eq this.step "map")}}
            <p class="text-gray-400">
                {{t "orchestrator.map-columns-desc"}}
                <strong class="dark:text-white">{{this.selectedFile.name}}</strong>
            </p>

            {{! Grouped sections }}
            {{#each this.fieldSections as |section|}}
                <div class="import-mapping-section">
                    <p class="import-mapping-section-title">{{section.label}}</p>
                    <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                        {{#each section.fields as |mapping|}}
                            <div class="input-group">
                                <label class="flex items-center gap-1">
                                    <span>{{mapping.label}}</span>
                                    {{#if mapping.required}}
                                        <span class="text-red-400">*</span>
                                    {{/if}}
                                    {{#if mapping.hint}}
                                        <span class="text-gray-500 font-normal">({{mapping.hint}})</span>
                                    {{/if}}
                                </label>
                                <Select
                                    @options={{this.fileColumnOptions}}
                                    @value={{mapping.mappedColumn}}
                                    @onChange={{fn this.setColumnMapping mapping}}
                                    @optionLabelPath="label"
                                    @optionValuePath="value"
                                    @placeholder={{t "orchestrator.select-column"}}
                                    @size="sm"
                                />
                            </div>
                        {{/each}}
                    </div>
                </div>
            {{/each}}

            {{! Preview of first 3 rows }}
            {{#if this.previewRows.length}}
                <div>
                    <p class="text-gray-400 mb-1">{{t "orchestrator.data-preview"}}</p>
                    <div class="overflow-x-auto rounded border dark:border-gray-700">
                        <table class="w-full text-xs">
                            <thead>
                                <tr class="dark:bg-gray-800">
                                    {{#each this.fileColumns as |col|}}
                                        <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">{{col}}</th>
                                    {{/each}}
                                </tr>
                            </thead>
                            <tbody>
                                {{#each this.previewRows as |row|}}
                                    <tr class="border-b dark:border-gray-700 last:border-0">
                                        {{#each this.fileColumns as |col|}}
                                            <td class="px-2 py-1.5 dark:text-gray-300 truncate max-w-24">{{get row col}}</td>
                                        {{/each}}
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            {{/if}}
        {{/if}}

        {{! ── Step 3: Preview & Confirm ── }}
        {{#if (eq this.step "preview")}}
            <div class="flex items-center justify-between">
                <p class="text-gray-400">
                    {{t "orchestrator.preview-desc" count=this.mappedRows.length}}
                </p>
                {{#if this.validationErrors.length}}
                    <Badge @status="error" @label={{concat this.validationErrors.length " " (t "orchestrator.errors")}} />
                {{else}}
                    <Badge @status="success" @label={{t "orchestrator.all-rows-valid"}} />
                {{/if}}
            </div>

            <div class="overflow-y-auto max-h-72 rounded border dark:border-gray-700">
                <table class="w-full text-xs">
                    <thead class="sticky top-0 dark:bg-gray-800">
                        <tr>
                            <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">#</th>
                            <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">{{t "orchestrator.col-pickup"}}</th>
                            <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">{{t "orchestrator.col-dropoff"}}</th>
                            <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">{{t "orchestrator.col-scheduled"}}</th>
                            <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">{{t "orchestrator.col-customer"}}</th>
                            <th class="px-2 py-1.5 text-left text-gray-400 font-medium border-b dark:border-gray-700">{{t "orchestrator.col-status"}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each this.mappedRows as |row index|}}
                            <tr class="border-b dark:border-gray-700 last:border-0 {{if row._error 'bg-red-900/20' ''}}">
                                <td class="px-2 py-1.5 text-gray-500">{{add index 1}}</td>
                                <td class="px-2 py-1.5 dark:text-gray-300 truncate max-w-32">{{row.pickup_street1}}</td>
                                <td class="px-2 py-1.5 dark:text-gray-300 truncate max-w-32">{{row.dropoff_street1}}</td>
                                <td class="px-2 py-1.5 dark:text-gray-300">{{row.scheduled_at}}</td>
                                <td class="px-2 py-1.5 dark:text-gray-300 truncate max-w-24">{{or row.customer_name row.customer_email ""}}</td>
                                <td class="px-2 py-1.5">
                                    {{#if row._error}}
                                        <span class="text-red-400" title={{row._error}}>
                                            <FaIcon @icon="exclamation-circle" class="mr-0.5" />{{t "orchestrator.error"}}
                                        </span>
                                    {{else}}
                                        <span class="text-green-400">
                                            <FaIcon @icon="check-circle" class="mr-0.5" />{{t "orchestrator.valid"}}
                                        </span>
                                    {{/if}}
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>

            {{#if this.validationErrors.length}}
                <div class="px-3 py-2 rounded bg-yellow-900/30 border border-yellow-700 text-yellow-400">
                    <FaIcon @icon="exclamation-triangle" class="mr-1" />
                    {{t "orchestrator.validation-warning" count=this.validationErrors.length}}
                </div>
            {{/if}}
        {{/if}}

    </div>
</Modal::Default>
