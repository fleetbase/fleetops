<ContentPanel @title={{t "order.fields.route-panel-title"}} @open={{true}} @actionButtons={{this.actionButtons}} @wrapperClass="bordered-top">
    {{#if this.hasTrackingRouteSummary}}
        <div class="mb-4 grid grid-cols-2 gap-2">
            <div class="rounded-md border border-gray-200 bg-gray-50 px-3 py-2 dark:border-gray-700 dark:bg-gray-900">
                <div class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Total Route Distance</div>
                <div class="mt-1 text-sm font-semibold text-gray-900 dark:text-gray-100">
                    {{#if this.hasTrackingDistance}}
                        {{format-meters this.trackerData.route.distance_m}}
                    {{else}}
                        -
                    {{/if}}
                </div>
            </div>
            <div class="rounded-md border border-gray-200 bg-gray-50 px-3 py-2 dark:border-gray-700 dark:bg-gray-900">
                <div class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Estimated Completion</div>
                <div class="mt-1 text-sm font-semibold text-gray-900 dark:text-gray-100">
                    {{#if this.hasCompletionEta}}
                        {{format-date-fns this.trackerData.eta.completion_at "d MMM HH:mm"}}
                    {{else}}
                        -
                    {{/if}}
                </div>
            </div>
        </div>
    {{/if}}

    {{#if @resource.hasIntermediateWaypoints}}
        <div>
            <RouteList @order={{@resource}} @eta={{@resource.eta}} @waypointActions={{hash viewWaypointLabel=(hash label=(t "order.fields.get-label") fn=this.viewWaypointLabel)}} />
        </div>
    {{else}}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-2">
            <div class="field-info-container">
                <label class="field-name">{{t "order.fields.pickup"}}</label>
                <DisplayPlace @place={{@resource.payload.pickup}} @eta={{get @resource.eta @resource.payload.pickup.id}} />
            </div>
            <div class="field-info-container">
                <label class="field-name">{{t "order.fields.dropoff"}}</label>
                <DisplayPlace @place={{@resource.payload.dropoff}} @eta={{get @resource.eta @resource.payload.dropoff.id}} />
            </div>
            <div class="field-info-container">
                <label class="field-name">{{t "order.fields.return"}}</label>
                <DisplayPlace @place={{@resource.payload.return}} />
            </div>
        </div>
    {{/if}}
</ContentPanel>