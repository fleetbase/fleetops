<ContentPanel @title={{t "order.fields.tracking"}} @prefixTitleRight={{@resource.tracking}} @isLoading={{@isLoading}} @open={{true}} @wrapperClass="bordered-top">
    {{#if this.hasTrackerData}}
        <div class="mb-5 space-y-4">
            <OrderProgressBar
                @order={{@resource}}
                @progress={{@resource.tracker_data.progress.percentage}}
                @firstWaypointCompleted={{gt @resource.tracker_data.progress.completed_stops 0}}
                @lastWaypointCompleted={{eq @resource.tracker_data.progress.percentage 100}}
            />

            <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
                <div class="field-info-container field-vertical-container">
                    <div class="field-name">Current ETA</div>
                    <div class="field-value text-lg">
                        {{#if this.isDueNow}}
                            Due now
                        {{else if this.hasActiveEta}}
                            {{format-duration this.activeEtaSeconds}}
                        {{else}}
                            -
                        {{/if}}
                    </div>
                </div>
                <div class="field-info-container field-vertical-container">
                    <div class="field-name">Completion ETA</div>
                    <div class="field-value text-lg">
                        {{#if this.hasCompletionEta}}
                            {{format-date-fns @resource.tracker_data.eta.completion_at "d MMM HH:mm"}}
                        {{else}}
                            -
                        {{/if}}
                    </div>
                </div>
                <div class="field-info-container field-vertical-container">
                    <div class="field-name">Remaining Distance</div>
                    <div class="field-value text-lg">
                        {{#if this.hasRemainingDistance}}
                            {{format-meters @resource.tracker_data.route.distance_m}}
                        {{else}}
                            -
                        {{/if}}
                    </div>
                </div>
                <div class="field-info-container field-vertical-container">
                    <div class="field-name">Remaining Stops</div>
                    <div class="field-value text-lg">{{n-a @resource.tracker_data.progress.remaining_stops}}</div>
                </div>
            </div>

            <div class="field-info-container field-vertical-container">
                <div class="field-name">Current Destination</div>
                <div class="field-value leading-5 normal-case break-words">{{n-a @resource.tracker_data.active_stop.address}}</div>
            </div>

            <div class="flex flex-col space-y-2 text-sm">
                <div class="flex flex-row items-center justify-between gap-3">
                    <div class="flex items-center min-w-0">
                        <FaIcon @icon="circle" @size="xs" class="mr-2 {{this.driverSignalClass}}" />
                        <span class="font-semibold {{this.driverSignalClass}}">{{this.driverSignal}}</span>
                        <span class="mx-2 text-gray-300 dark:text-gray-600">&middot;</span>
                        <span class="truncate text-gray-500 dark:text-gray-400">
                            {{#each this.routeQualityItems as |item index|}}
                                {{#if index}}<span class="mx-1">&middot;</span>{{/if}}{{item}}
                            {{/each}}
                        </span>
                    </div>
                    <div class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap">
                        Updated
                        {{n-a (format-date-fns @resource.tracker_data.generated_at "d MMM HH:mm")}}
                    </div>
                </div>

                {{#if this.operatorWarning}}
                    <InfoBlock @type="warning" @icon="triangle-exclamation" @text={{this.operatorWarning}} class="py-2" />
                {{/if}}
            </div>
        </div>
    {{/if}}

    <div class="text-xs uppercase tracking-wide font-semibold text-gray-500 dark:text-gray-400 mb-2">Labels</div>
    <div class="flex flex-col border border-gray-200 bg-gray-50 dark:bg-gray-900 dark:border-gray-700 rounded-md px-4 py-4 shadow-sm">
        <div class="flex flex-row items-center justify-center space-x-4">
            <div class="rounded-md bg-white p-2">
                <img src={{concat "data:image/png;base64," @resource.tracking_number.qr_code}} class="w-14 h-14" alt={{@resource.public_id}} />
            </div>
            <div class="rounded-md bg-white p-2">
                <img src={{concat "data:image/png;base64," @resource.tracking_number.barcode}} class="w-40 h-14" alt={{@resource.public_id}} />
            </div>
        </div>
        <div class="mt-4 flex justify-center items-center">
            <Button @size="xs" @type="default" @icon="barcode" @text="Get Order Label" @onClick={{fn this.orderActions.viewLabel @resource}} @permission="fleet-ops view order" />
        </div>
    </div>
</ContentPanel>