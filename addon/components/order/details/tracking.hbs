<ContentPanel @title={{t "order.fields.tracking"}} @prefixTitleRight={{@resource.tracking}} @isLoading={{@isLoading}} @open={{true}} @wrapperClass="bordered-top">
    {{#if this.hasTrackerData}}
        <div class="mb-4 space-y-3">
            <OrderProgressBar
                @order={{@resource}}
                @progress={{@resource.tracker_data.progress.percentage}}
                @firstWaypointCompleted={{gt @resource.tracker_data.progress.completed_stops 0}}
                @lastWaypointCompleted={{eq @resource.tracker_data.progress.percentage 100}}
            />

            <div class="grid grid-cols-2 gap-2">
                <div class="field-info-container field-vertical-container py-2">
                    <div class="field-name">Current ETA</div>
                    <div class="field-value text-sm font-semibold leading-5">
                        {{#if this.isDueNow}}
                            Due now
                        {{else if this.hasActiveEta}}
                            {{format-duration this.activeEtaSeconds}}
                        {{else}}
                            -
                        {{/if}}
                    </div>
                </div>
                <div class="field-info-container field-vertical-container py-2">
                    <div class="field-name">Completion ETA</div>
                    <div class="field-value text-sm font-semibold leading-5">
                        {{#if this.hasCompletionEta}}
                            {{format-date-fns @resource.tracker_data.eta.completion_at "d MMM HH:mm"}}
                        {{else}}
                            -
                        {{/if}}
                    </div>
                </div>
            </div>

            <div class="field-info-container field-vertical-container py-2">
                <div class="field-name">Current Destination</div>
                <div class="field-value text-sm leading-5 normal-case break-words">{{n-a @resource.tracker_data.active_stop.address}}</div>
            </div>

            <div class="grid grid-cols-2 gap-2">
                <div class="field-info-container field-vertical-container py-2">
                    <div class="field-name">Remaining Distance</div>
                    <div class="field-value text-sm font-semibold leading-5">
                        {{#if this.hasRemainingDistance}}
                            {{format-meters @resource.tracker_data.route.distance_m}}
                        {{else}}
                            -
                        {{/if}}
                    </div>
                </div>
                <div class="field-info-container field-vertical-container py-2">
                    <div class="field-name">Remaining Stops</div>
                    <div class="field-value text-sm font-semibold leading-5">{{n-a @resource.tracker_data.progress.remaining_stops}}</div>
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs leading-5 text-gray-500 dark:text-gray-400">
                <span class="inline-flex items-center font-semibold {{this.driverSignalClass}}">
                    <FaIcon @icon="circle" @size="2xs" class="mr-1" />
                    {{this.driverSignal}}
                </span>
                {{#each this.routeQualityItems as |item|}}
                    <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                    <span>{{item}}</span>
                {{/each}}
                <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                <span>Updated {{n-a (format-date-fns @resource.tracker_data.generated_at "d MMM HH:mm")}}</span>
            </div>

            {{#if this.operatorWarning}}
                <div class="flex items-start rounded-md border border-yellow-500/40 bg-yellow-500/10 px-2 py-1.5 text-xs leading-5 text-yellow-700 dark:text-yellow-200">
                    <FaIcon @icon="triangle-exclamation" @size="xs" class="mt-1 mr-2 shrink-0" />
                    <span>{{this.operatorWarning}}</span>
                </div>
            {{/if}}
        </div>
    {{/if}}

    <div class="text-xs uppercase tracking-wide font-semibold text-gray-500 dark:text-gray-400 mb-2">Labels</div>
    <div class="flex flex-col border border-gray-200 bg-gray-50 dark:bg-gray-900 dark:border-gray-700 rounded-md px-3 py-3 shadow-sm">
        <div class="flex flex-row items-center justify-center space-x-3">
            <div class="rounded-md bg-white p-2">
                <img src={{concat "data:image/png;base64," @resource.tracking_number.qr_code}} class="w-12 h-12" alt={{@resource.public_id}} />
            </div>
            <div class="rounded-md bg-white p-2">
                <img src={{concat "data:image/png;base64," @resource.tracking_number.barcode}} class="w-36 h-12" alt={{@resource.public_id}} />
            </div>
        </div>
        <div class="mt-2 flex justify-center items-center">
            <Button @size="xs" @type="default" @icon="barcode" @text="Get Order Label" @onClick={{fn this.orderActions.viewLabel @resource}} @permission="fleet-ops view order" />
        </div>
    </div>
</ContentPanel>